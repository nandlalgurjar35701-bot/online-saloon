<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product Package</title>

  <%- include('../../partials/headlink.ejs') %>
</head>

<body>
  <%- include('../../partials/Header.ejs') %>
    <%- include("../../partials/sidebar.ejs") %>
      <%- include("../../partials/alertMsg") %>
        <main id="main" class="main">
          <div class="pagetitle">
            <h1>
              <%-user?.type %>
            </h1>
            <nav>
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active">Dashboard</li>
              </ol>
            </nav>
          </div><!-- End Page Title -->

          <section class="section dashboard">
            <div class="row">
              <div class="row">
                <div class="col-lg-12">
                  <div class="card">
                    <div class="card-body">

                      <h5 class="card-title">Add Product Package</h5>
                      
                          <% if(data){ %>
                            <form class="needs-validation" action="/add-product-package?id=<%= data._id%>" method="post"
                              enctype="multipart/form-data" novalidate>
                              <% }else{ %>

                                <form class="needs-validation" action="/add-product-package" method="post"
                                  enctype="multipart/form-data" novalidate>
                                  <% } %>
                                    <div class="row g-3">
                                      <div class="col">
                                        <label for=""> package Name</label>
                                        <input required type="text" name="ServiceName" class="form-control"
                                          placeholder="Enter package Name" value="<%= data?.ServiceName %>">
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Please Enter package Name.</div>
                                      </div>
                                      <div class="col">
                                        <label for="">Time</label>
                                        <input required type="number" name="timePeriod_in_minits" class="form-control"
                                          placeholder="Enter Time " value="<%= data?.timePeriod_in_minits %>">
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Please Enter package Time.</div>
                                      </div>

                                    </div><br>



                                    <div class="row g-3">
                                      <div class="col">
                                        <label for="">Discription</label>
                                        <textarea class="form-control" name="description"
                                          placeholder="Enter Description" style="height: 100px" required
                                          minlength="5"><%= data?.description %></textarea>
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Please Enter Discription.</div>
                                      </div>
                                      <div class="col">
                                        <label for="">package Images</label>
                                        <% if(data){ %>
                                          <input class="form-control" type="file" name="file" id="formFile">

                                          <% }else{ %>
                                            <input class="form-control" type="file" name="file" id="formFile" required>
                                            <% } %>
                                              <div class="valid-feedback">Looks good!</div>
                                              <div class="invalid-feedback">Please select Image.</div>
                                              <img src="/uploads/<%= Array.isArray(data?.image) ? (data?.image?.[0] || 'default.png') : (data?.image || 'default.png') %>"
                                                style="max-width: 200px; max-height: 68px;" alt="img">
                                      </div>
                                    </div><br>

                                    <div class="row g-3">
                                      <div class="col">
                                        <label for="">Select Category</label>
                                        <select class="form-select" name="category" aria-label="multiple select example"
                                          required>
                                          <option value="">Select Category</option>
                                          <% Category.data.forEach(element=> {%>
                                            <option value="<%=element._id%>" <%= data?.category?.toString() === element._id.toString() ? 'selected' : '' %>>
                                              <%=element.Name%>
                                            </option>
                                            <% });%>
                                        </select>
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Please Select Category.</div>
                                      </div>
                                      <div class="col">
                                        <label for="">Select Saloon</label>
                                        <select class="form-select" name="saloonStore" id="saloonStore"
                                          aria-label="Default select example"
                                          onchange="FindService(this) ,FindSaloon(this)" required>
                                          <option value="">Select Saloon</option>
                                          <% salon.forEach(element=> {%>
                                            <option value="<%=element._id%>" <%= data?.saloonStore?.toString() === element._id.toString() ? 'selected' : '' %>>
                                              <%=element.storeName%>
                                            </option>
                                            <% });%>
                                        </select>
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Please Select Saloon.</div>
                                      </div>
                                    </div><br>
                                    <div class="row g-3">

                                      <div class="col">
                                        <label for="">Choose Gender </label>
                                        <div id="gendeAll">

                                        </div>
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Please Select Gender.</div>
                                      </div>
                                      <div class="col">
                                        <label for=""> package Price</label>
                                        <input required type="number" name="ServicePrice" id="Amount"
                                          class="form-control" placeholder="Enter package Price"
                                          value="<%= data?.ServicePrice %>" readonly>
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Please Enter package Price.</div>
                                      </div>
                                    </div><br>

                                    <div class="row g-3">
                                      <div class="col">
                                        <label for="">Select Products</label>
                                        <select style="width:100%;" multiple class="form-select" id="txtSelectedValues"
                                          onchange="ServicePriceTotel()" name="Services" required>
                                          <option value="" disabled>Select Saloon First</option>
                                        </select>
                                        <div class="invalid-feedback">Please select at least one product.</div>
                                        <div id="selectedServicesBox" class="mt-2"></div>
                                      </div>
                                      <div class="col">
                                        <label for="">package Final Price</label> <br>
                                        <input class="form-control" type="number" name="FinalPrice"
                                          value="<%= data?.FinalPrice %>" id="FinalPrice" required>
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Please select Image.</div>
                                      </div>
                                    </div><br>


                                    <div class="row mb-3">
                                      <div class="col-sm-10">
                                        <button type="submit" id='mySubmit' class="btn btn-primary">Submit</button>
                                      </div>
                                    </div>
                                </form>


                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>
        </main>
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js"></script>
        <script src="/public/assets/js/form-validation.js"></script>

        <script>

          $(document).ready(function () {
            const salonSelect = document.getElementById("saloonStore")
            if (salonSelect?.value) {
              FindService(salonSelect)
              FindSaloon(salonSelect)
            } else {
              $('#selectedServicesBox').html('<small class="text-muted">No product selected.</small>');
            }
          });
          let selectedServiceIds;
          <% if (data?.Services?.length > 0) {%>
            selectedServiceIds = <%- JSON.stringify(data.Services) %>
          <% } else {%>
            selectedServiceIds = []
              <% }%>
          function normalizeIdList(list) {
            return (list || []).map((item) => item.toString());
          }

          function renderSelectedServices() {
            const selectedOptions = $('#txtSelectedValues option:selected');
            if (selectedOptions.length === 0) {
              $('#selectedServicesBox').html('<small class="text-muted">No product selected.</small>');
              return;
            }

            let tags = '';
            selectedOptions.each(function () {
              tags += `<span class="badge bg-primary me-1 mb-1">${$(this).text()}</span>`;
            });
            $('#selectedServicesBox').html(tags);
          }

          function FindService(select) {
            const salonId = select.value;
            if (!salonId) {
              $('#txtSelectedValues').html('<option value="" disabled selected>Select Saloon First</option>');
              $('#Amount').val(0);
              $('#selectedServicesBox').html('<small class="text-muted">No product selected.</small>');
              return;
            }

            $.ajax({
              type: 'get',
              data: { saloonId: salonId },
              url: '/find-services-for-product-package',
              success: function (data) {
                if (data.length === 0) {
                  $('#txtSelectedValues').html('<option value="" disabled selected>No products found</option>');
                  $('#selectedServicesBox').html('<small class="text-muted">No products found for this saloon.</small>');
                  $('#Amount').val(0);
                  return;
                }

                const preselectedIds = normalizeIdList(selectedServiceIds);
                let html = '';
                data.forEach((item) => {
                  const value = JSON.stringify({
                    id: item._id,
                    amount: Number(item.ServicePrice || 0)
                  });
                  const isSelected = preselectedIds.includes(item._id.toString()) ? 'selected' : '';
                  html += `<option value='${value}' ${isSelected}>${item.ServiceName}</option>`;
                });

                $('#txtSelectedValues').html(html);
                ServicePriceTotel();
                selectedServiceIds = [];
              }
            });
          }

          function ServicePriceTotel() {
            const selectedValues = $('#txtSelectedValues').val() || [];
            let sum = 0;
            selectedValues.forEach((element) => {
              const data = JSON.parse(element);
              sum += Number(data.amount || 0);
            });
            $('#Amount').val(sum);
            renderSelectedServices();
          }


        </script>
        <script>
          const amountInput = document.getElementById('Amount');
          const finalPriceInput = document.getElementById('FinalPrice');
          const existingPackageType = "<%= data?.type || '' %>";

          amountInput.addEventListener('input', () => {
            finalPriceInput.value = Math.min(amountInput.value, finalPriceInput.value);
          });
          finalPriceInput.addEventListener('input', () => {
            finalPriceInput.value = Math.min(amountInput.value, finalPriceInput.value);
          });




          function FindSaloon(a) {
            $.ajax({
              type: 'get',
              data: { id: a.value },
              url: '/find-saloon',
              success: function (data) {
                const element = document.getElementById("Gender")

                if (data.type == "male") {
                  $('#Gender').remove()
                  let abc;
                  abc = ` <select class="form-select" name="type" id="Gender" aria-label="Default select example"
                                  required>
                                <option value="male" selected>Male</option>
                          </select>`
                  $('#gendeAll').append(abc)
                } else if (data.type == "female") {
                  $('#Gender').remove()
                  let abc;
                  abc = `<select class="form-select" name="type" id="Gender" aria-label="Default select example"
                                  required>
                                 <option value="female" selected>Female</option>
                          </select>`

                  $('#gendeAll').append(abc)
                } else {
                  $('#Gender').remove()
                  let abc;
                  abc = `<select class="form-select" name="type" id="Gender" aria-label="Default select example"
                                  required>
                                  <option value="">Select Type</option>
                                  <option value="male" ${existingPackageType === "male" ? "selected" : ""}>Male</option>
                                  <option value="female" ${existingPackageType === "female" ? "selected" : ""}>Female</option>
                                  <option value="unisex" ${existingPackageType === "unisex" ? "selected" : ""}>Unisex</option>
                                </select>`
                  $('#gendeAll').append(abc)
                };
              }
            });
          };
        </script>

        <%- include("../../partials/script.ejs") %>
</body>


</html>
