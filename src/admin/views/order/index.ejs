<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>view-Order</title>
  <%- include('../../partials/headlink.ejs') %>
</head>

<body>
  <%- include('../../partials/Header.ejs') %>
    <%- include("../../partials/sidebar.ejs") %>

      <main id="main" class="main">
        <div class="pagetitle">

          <h1><%-user.type %></h1>
          <nav>
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/admin/">Home</a></li>
              <li class="breadcrumb-item active">Dashboard</li>
            </ol>
          </nav>
        </div>
        <!-- End Page Title -->
        <section class="section dashboard">
          <div class="row">
            <div class="row">
              <div class="col-lg-12">
                <div class="card">
                  <div class="card-body">
                    <h5 class="card-title">Filter</h5>

                    <!-- No Labels Form -->
                    <% if(typeof query.userId !=="undefined" && query.userId){%>
                      <form class="row g-3" action="/admin/get-All-order?userId=<%=query.userId%>">
                        <input type="hidden" name="userId" value="<%=query.userId%>">
                        <%}else{%>
                          <form class="row g-3" action="/admin/get-All-order">
                            <%}%>

                              <!-- <form class="row g-3" action="/admin/get-All-order"> -->
                              <div class="col-md-3">
                                <label>Choose City</label> <br>
                                <select id="inputState" name="city" class="form-select">
                                  <% if( query.city!=undefined&&query.city!="" ){%>
                                    <option selected="" value="<%=query?.city%>">
                                      <%=query?.city%>
                                    </option>
                                    <option value="">Choose City</option>
                                    <%}else{%>
                                      <option selected="" value="">Choose City</option>
                                      <%}%>
                                        <% city.forEach(function(citys) { %>
                                          <option value="<%=citys%>">
                                            <%=citys%>
                                          </option>
                                          <% }); %>
                                </select>
                              </div>
                              <div class="col-md-3">
                                <label>Status Type</label> <br>
                                <select id="inputState" name="status" class="form-select">
                                  <% if( query?.status=="pending" ){%>
                                    <option value="">Choose Status</option>
                                    <option selected="" value="pending">pending</option>
                                    <option value="cancel">cancel</option>
                                    <option value="succes">succes</option>
                                    <%}else if( query?.status=="cancel" ){%>
                                      <option value="">Choose Status</option>
                                      <option value="pending">pending</option>
                                      <option selected="" value="cancel">cancel</option>
                                      <option value="succes">succes</option>
                                      <%}else if( query?.status=="succes" ){%>
                                        <option value="">Choose Status</option>
                                        <option value="pending">pending</option>
                                        <option value="cancel">cancel</option>
                                        <option selected="" value="succes">succes</option>
                                        <%}else{%>
                                          <option selected="" value="">Choose Status</option>
                                          <option value="pending">pending</option>
                                          <option value="cancel">cancel</option>
                                          <option value="succes">succes</option>
                                          <%}%>

                                </select>
                              </div>
                              <div class="col-md-3">
                                <label>Amount</label> <br>

                                <% if(query?.totalamount!="" ){ %>
                                  <input type="number" name="totalamount" class="form-control"
                                    value="<%=query?.totalamount%>" placeholder="Enter Amount">
                                  <%}else{%>
                                    <input type="number" name="totalamount" class="form-control" placeholder="Amount">
                                    <%}%>
                              </div>
                              <div class="col-md-3">
                                <label></label> <br>

                                <div class="text-center">
                                  <button type="submit" class="btn btn-primary">Submit</button>
                                  <% if(typeof query.userId !=="undefined" && query.userId){%>
                                    <a href="/admin/get-All-order?userId=<%=query.userId%>""> <button type=" button"
                                      class="btn btn-secondary">Reset</button></a>
                                    <%}else{%>
                                      <a href="/admin/get-All-order"> <button type="button"
                                          class="btn btn-secondary">Reset</button></a>
                                      <%}%>
                                </div>
                              </div>
                          </form>
                          <!-- End No Labels Form -->

                  </div>
                </div>
                <div class="card">
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                      <h5 class="card-title mb-0">Order List</h5>
                    </div>

                    <!-- Table with stripped rows -->
                    <table class="table datatable text-nowrap">
                      <thead>
                        <tr>
                          <th scope="col">#</th>
                          <th scope="col">Store Name</th>
                          <th scope="col">User Name</th>
                          <th scope="col" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Cart Data">
                            C.D.</th>
                          <th scope="col">Date And Time</th>
                          <th scope="col" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Total Amount">
                            T.A.</th>
                          <th scope="col">Payment Status</th>
                          <th scope="col">Status</th>

                          <th scope="col">Action</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% let i=0 %>
                          <% for( data of data) { %>
                            <tr data-order-id="<%=data._id%>">
                              <th scope="row">
                                <%= ++i %>
                              </th>
                              <td>
                                <%= data.saloon?.storeName %>
                              </td>
                              <td>
                                <%= data.users?.name %>
                              </td>
                              <td>
                                <% if( data.status=="succes" ){%>
                                  <button type="button" value="<%=data._id%>" data-status="<%=data.status%>"
                                    onclick="openEditCart(this)" class="btn btn-secondary" data-bs-toggle="tooltip"
                                    data-bs-placement="top" data-bs-title="View Cart"><i class="bi bi-eye"></i></button>
                                <%}else{%>
                                  <button type="button" value="<%=data._id%>" data-status="<%=data.status%>"
                                    onclick="openEditCart(this)" class="btn btn-info" data-bs-toggle="tooltip"
                                    data-bs-placement="top" data-bs-title="Edit Cart"><i class="bi bi-eye"></i></button>
                                <%}%>
                              </td>
                              <td>
                                <% if(typeof data.Schedule !=="undefined" && data.Schedule){%>
                                  <%= data.Schedule.date %>
                                    <%= data.Schedule.timeslot %>
                                      <%}else{%>
                                        date :<br>
                                        timeslot :
                                        <%}%>
                              </td>
                              <td class="js-total-amount">
                                <%= data.totalamount %>
                              </td>
                              <td>
                                <%= data.pay?.payment %>
                              </td>
                              <td>
                                <%= data.status %>
                              </td>
                              <td>
                                <% if( data.status=="succes" ){%>
                                  <a href="#" class="btn btn-dark">Succes</a>

                                  <%}else if( data.status=="cancel" ){%>
                                    <a href="#" class="btn btn-danger">Cancel</a>
                                    <%}else{%>
                                      <a href="/admin/Admin-Order-Approve?id=<%= data._id%>" class="btn btn-success js-approve-order"
                                        data-payment-status="<%= data.paymentStatus || '' %>"
                                        data-bs-toggle="tooltip" data-bs-placement="top"
                                        data-bs-title="Approve Order"><i class="bi bi-check2-circle"></i></a>
                                      <a href="/admin/Admin-Order-Cancel?id=<%= data._id%>" class="btn btn-danger js-cancel-order"
                                        data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Decline Order">
                                        <span aria-hidden="true">&times;</span></a>
                                      <%}%>
                              </td>
                            </tr>

                            <%}%>
                      </tbody>
                    </table>
                    <!-- End Table with stripped rows -->

                  </div>
                </div>
              </div>
            </div>

          </div>
        </section>


      </main>
      <div class="modal fade" id="editCartModal" tabindex="-1" aria-labelledby="editCartModalLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="editCartModalLabel">Edit Cart Items</h5>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary btn-sm" onclick="openAddItemModal()">Add Item</button>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
            </div>
            <div class="modal-body">
              <input type="hidden" id="editOrderId" value="" />
              <div id="editCartBody">
                ...
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="modal fade" id="addItemModal" tabindex="-1" aria-labelledby="addItemModalLabel"
        aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="addItemModalLabel">Add Item</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-12 position-relative">
                  <label>Service</label>
                  <input id="addServiceSearch" type="text" class="form-control" placeholder="Search and select service" />
                  <input type="hidden" id="addServiceId" value="" />
                  <div id="serviceDropdownList" class="list-group position-absolute w-100" style="z-index: 1056; display: none;"></div>
                </div>
                <div class="col-12">
                  <label>Quantity</label>
                  <input id="addServiceQty" type="number" class="form-control" value="1" min="1" />
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
              <button type="button" class="btn btn-primary" onclick="addItemToOrder()">Add</button>
            </div>
          </div>
        </div>
      </div>

      <div class="modal fade" id="approveConfirmModal" tabindex="-1" aria-labelledby="approveConfirmModalLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="approveConfirmModalLabel">Confirm Approval</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="approveConfirmMessage">
              ...
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="button" class="btn btn-success" id="approveConfirmYes">Approve</button>
            </div>
          </div>
        </div>
      </div>

      <div class="modal fade" id="cancelConfirmModal" tabindex="-1" aria-labelledby="cancelConfirmModalLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="cancelConfirmModalLabel">Confirm Cancel</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              Are you sure you want to cancel this order?
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
              <button type="button" class="btn btn-danger" id="cancelConfirmYes">Yes, Cancel</button>
            </div>
          </div>
        </div>
      </div>


      <script>
        let editSaloonId = "";
        let servicePage = 1;
        let searchTimer = null;

        function openEditCart(btn) {
          const orderId = btn.value;
          $("#editOrderId").val(orderId);

          $.ajax({
            type: 'get',
            data: { "id": orderId },
            url: '/admin/Admin-Order-Cart-Data',
            success: function (resp) {
              const items = resp && resp.items ? resp.items : [];
              editSaloonId = resp && resp.saloonId ? resp.saloonId : "";
              const status = String(btn.getAttribute("data-status") || "").toLowerCase();
              const readOnly = status === "succes";

              if (readOnly) {
                $("#editCartModalLabel").text("View Cart Items");
                $("#editCartModal .btn.btn-primary.btn-sm").hide();
              } else {
                $("#editCartModalLabel").text("Edit Cart Items");
                $("#editCartModal .btn.btn-primary.btn-sm").show();
              }

              let html = `<table class="table text-nowrap">
                <thead>
                  <tr>
                    <th scope="col">#</th>
                    <th scope="col">Service</th>
                    <th scope="col">Qty</th>
                    <th scope="col">Amount</th>
                    ${readOnly ? "" : "<th scope='col'>Action</th>"}
                  </tr>
                </thead>
                <tbody>`;

              let i = 1;
              items.forEach((item) => {
                html += `<tr data-service-id="${item.serviceId}">
                  <th scope="row">${i}.</th>
                  <td>${item.ServiceName || "-"}</td>
                  <td>
                    ${readOnly
                      ? `<span class="badge bg-light text-dark">${item.quantity || 0}</span>`
                      : `<div class="btn-group" role="group">
                          <button class="btn btn-outline-secondary btn-sm" onclick="updateQty('${item.serviceId}','dec')">-</button>
                          <span class="btn btn-light btn-sm">${item.quantity || 0}</span>
                          <button class="btn btn-outline-secondary btn-sm" onclick="updateQty('${item.serviceId}','inc')">+</button>
                        </div>`}
                  </td>
                  <td>${item.Amount || 0}</td>
                  ${readOnly ? "" : `<td><button class="btn btn-danger btn-sm" onclick="removeItem('${item.serviceId}')">Remove</button></td>`}
                </tr>`;
                i++;
              });

              html += `</tbody></table>`;
              $("#editCartBody").html(html);

              const modalEl = document.getElementById("editCartModal");
              const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
              modal.show();
            }
          });
        }

        function openAddItemModal() {
          servicePage = 1;
          $("#addServiceSearch").val("");
          $("#addServiceId").val("");
          $("#serviceDropdownList").hide().html("");
          $("#addServiceQty").val(1);

          const modalEl = document.getElementById("addItemModal");
          const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
          modal.show();

          searchServices(1);
        }

        function updateMainTotal(orderId, totalamount) {
          if (!orderId) return;
          const row = document.querySelector(`tr[data-order-id="${orderId}"]`);
          if (!row) return;
          const cell = row.querySelector(".js-total-amount");
          if (cell && totalamount != null) {
            cell.textContent = totalamount;
          }
        }

        function renderServiceResults(items) {
          if (!items || items.length === 0) {
            $("#serviceDropdownList").html(`<div class="list-group-item text-muted">No results</div>`).show();
            return;
          }
          let html = "";
          items.forEach((svc) => {
            const name = svc.ServiceName || "-";
            const price = svc.ServicePrice || 0;
            html += `<button type="button" class="list-group-item list-group-item-action" onclick="selectService('${svc._id}','${name}','${price}')">
              ${name} (Rs ${price})
            </button>`;
          });
          $("#serviceDropdownList").html(html).show();
        }

        function selectService(id, name, price) {
          $("#addServiceSearch").val(`${name} (Rs ${price})`);
          $("#addServiceId").val(id);
          $("#serviceDropdownList").hide();
        }

        function searchServices(page) {
          if (!editSaloonId) return;
          const q = $("#addServiceSearch").val() || "";
          const pageNum = page || 1;
          $.ajax({
            type: 'get',
            url: '/admin/Admin-Order-Search-Services',
            data: { saloonId: editSaloonId, q, page: pageNum, limit: 5 },
            success: function (resp) {
              const items = resp && resp.items ? resp.items : [];
              servicePage = resp && resp.page ? resp.page : 1;
              serviceTotalPages = resp && resp.totalPages ? resp.totalPages : 1;
              renderServiceResults(items);
            }
          });
        }

        function addItemToOrder(serviceId) {
          const orderId = $("#editOrderId").val();
          if (!serviceId) {
            serviceId = $("#addServiceId").val();
          }
          const qty = Number($("#addServiceQty").val() || 1);
          if (!orderId || !serviceId) return;

          $.ajax({
            type: 'post',
            url: '/admin/Admin-Order-Update-Cart',
            data: { orderId, action: "add", serviceId, quantity: qty },
            success: function (resp) {
              const addModal = bootstrap.Modal.getOrCreateInstance(document.getElementById("addItemModal"));
              addModal.hide();
              updateMainTotal(orderId, resp && resp.totalamount);
              openEditCart({ value: orderId });
            }
          });
        }

        $("#addServiceSearch").on("input", function () {
          $("#addServiceId").val("");
          if (searchTimer) clearTimeout(searchTimer);
          searchTimer = setTimeout(function () {
            searchServices(1);
          }, 300);
        });

        $(document).on("click", function (e) {
          const target = $(e.target);
          if (!target.closest("#addServiceSearch").length && !target.closest("#serviceDropdownList").length) {
            $("#serviceDropdownList").hide();
          }
        });

        function updateQty(serviceId, action) {
          const orderId = $("#editOrderId").val();
          if (!orderId || !serviceId) return;
          $.ajax({
            type: 'post',
            url: '/admin/Admin-Order-Update-Cart',
            data: { orderId, action, serviceId },
            success: function (resp) {
              updateMainTotal(orderId, resp && resp.totalamount);
              openEditCart({ value: orderId });
            }
          });
        }

        function removeItem(serviceId) {
          const orderId = $("#editOrderId").val();
          if (!orderId || !serviceId) return;
          $.ajax({
            type: 'post',
            url: '/admin/Admin-Order-Update-Cart',
            data: { orderId, action: "remove", serviceId },
            success: function (resp) {
              updateMainTotal(orderId, resp && resp.totalamount);
              openEditCart({ value: orderId });
            }
          });
        }

        $(document).on("click", ".js-approve-order", function (e) {
          e.preventDefault();
          const link = this.getAttribute("href");
          const paymentStatus = String(this.getAttribute("data-payment-status") || "").toLowerCase();
          let message = "Are you sure you want to approve this order?";
          if (paymentStatus === "offline-store") {
            message = "Are you sure you want to approve this offline order?";
          } else {
            message = "Have you received the payment for this order?";
          }
          $("#approveConfirmMessage").text(message);
          $("#approveConfirmYes").data("href", link);
          const modalEl = document.getElementById("approveConfirmModal");
          const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
          modal.show();
        });

        $("#approveConfirmYes").on("click", function () {
          const link = $(this).data("href");
          if (link) {
            window.location.href = link;
          }
        });

        $(document).on("click", ".js-cancel-order", function (e) {
          e.preventDefault();
          const link = this.getAttribute("href");
          $("#cancelConfirmYes").data("href", link);
          const modalEl = document.getElementById("cancelConfirmModal");
          const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
          modal.show();
        });

        $("#cancelConfirmYes").on("click", function () {
          const link = $(this).data("href");
          if (link) {
            window.location.href = link;
          }
        });
      </script>
      <%- include("../../partials/script.ejs") %>
</body>

</html>
