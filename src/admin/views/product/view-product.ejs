<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>view-Product</title>
  <%- include('../../partials/headlink.ejs') %>
</head>

<body>
  <%- include('../../partials/Header.ejs') %>
    <%- include("../../partials/sidebar.ejs") %>
      <%- include("../../partials/alertMsg") %>

        <main id="main" class="main">
          <div class="pagetitle">
            <h1><%-user?.type %></h1>
            <nav>
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active">Dashboard</li>
              </ol>
            </nav>
          </div>
          <!-- End Page Title -->
          <section class="section dashboard">
            <div class="row">
              <div class="row">
                <div class="col-lg-12">
                  <div class="card">
                    <div class="card-body">
                      <h5 class="card-title">Filter</h5>

                      <!-- No Labels Form -->
                      <form class="row g-3" action="/view-product">
                        <div class="col-md-4">
                          <label>Enter Service Name</label> <br>
                          <% if(query?.ServiceName!="" ){%>
                            <input type="text" name="ServiceName" class="form-control" value="<%=query?.ServiceName%>"
                              placeholder="ServiceName">
                            <%}else{%>
                              <input type="text" name="ServiceName" class="form-control" placeholder="ServiceName">
                              <%}%>
                        </div>
                        <div class="col-md-4">
                          <label>Enter Service Price Amount</label> <br>
                          <% if(query?.ServicePrice!="" ){%>
                            <input type="number" name="ServicePrice" class="form-control"
                              value="<%=query?.ServicePrice%>" placeholder="ServicePrice">
                            <%}else{%>
                              <input type="number" name="ServicePrice" class="form-control" placeholder="ServicePrice">
                              <%}%>
                        </div>
                        <div class="col-md-4">
                          <label>Enter Category Name</label> <br>
                          <input type="text" name="CategoryName" class="form-control" value="<%= query?.CategoryName %>"
                            placeholder="CategoryName">
                        </div>
                        <div class="col-md-4">

                        </div>
                        <div class="col-md-3">
                          <label></label> <br>
                          <div class="text-center">
                            <button type="submit" class="btn btn-primary">Submit</button>
                            <a href="/view-product"> <button type="button" class="btn btn-secondary">Reset</button></a>
                          </div>
                        </div>
                      </form>
                      <!-- End No Labels Form -->

                    </div>
                  </div>
                  <div class="card">
                    <div class="card-body">
                      <div class="d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Product List</h5>
                        <a href="/add-product" class="btn btn-primary btn-sm">Add Product</a>
                      </div>

                      <!-- Table with stripped rows -->
                      <table class="table datatable">
                        <thead>
                          <tr>
                            <th scope="col">#</th>
                            <th scope="col">Service Name</th>
                            <th scope="col"> Price</th>
                            <th scope="col">Time(min) </th>
                            <th scope="col">Image</th>
                            <th scope="col"> Category </th>
                            <th scope="col">Action</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% let i=0 %>
                            <% for( data of data) { %>
                              <tr>
                                <th scope="row">
                                  <%= ++i %>
                                </th>
                                <td>
                                  <%= data?.ServiceName %>
                                </td>
                                <td>
                                  <%= data?.ServicePrice %>
                                </td>
                                <td>
                                  <%= data?.timePeriod_in_minits %>
                                </td>
                                <td>
                                  <% const productImages = (Array.isArray(data?.image) && data.image.length > 0) ? data.image : ["default.png"]; %>
                                  <img
                                    src="/uploads/<%= productImages[0] %>"
                                    alt="product-image"
                                    class="rounded border product-thumb"
                                    data-images='<%- JSON.stringify(productImages) %>'
                                    style="width: 52px; height: 52px; object-fit: cover; cursor: zoom-in;">
                                </td>
                                <td>
                                  <%= data?.category?.Name || "?" %>
                                </td>
                                <td>
                                  <a href="/add-product?id=<%= data._id%>" class="btn btn-info" data-bs-toggle="tooltip"
                                    data-bs-placement="top" data-bs-title="Edit"><i class="ri-edit-box-line"></i></a>
                                  <a href="/delete-product?id=<%= data._id%>" class="btn btn-danger"
                                    data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="delete">
                                    <i class="ri-delete-bin-5-line" title="delete"></i>
                                  </a>
                                  <!-- <a href="/add_service?id=<%= data._id%>" class="btn btn-dark">Edit</a>
                                <a href="/delete_service?id=<%= data._id%>" class="btn btn-danger">Delete</a> -->
                                </td>
                              </tr>
                              <%}%>
                        </tbody>
                      </table>
                      <!-- End Table with stripped rows -->

                    </div>
                  </div>
                </div>
              </div>

            </div>
          </section>

        </main>

        <div class="modal fade" id="productImageModal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Product Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body text-center">
                <img id="zoomedProductImage" src="" alt="zoomed-product-image"
                  style="max-width: 100%; max-height: 70vh; object-fit: contain;">
                <div class="d-flex justify-content-between align-items-center mt-3">
                  <button type="button" id="prevImageBtn" class="btn btn-outline-secondary btn-sm" aria-label="Previous image">&larr;</button>
                  <small id="imageCounter" class="text-muted">1 / 1</small>
                  <button type="button" id="nextImageBtn" class="btn btn-outline-secondary btn-sm" aria-label="Next image">&rarr;</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <%- include("../../partials/script.ejs") %>
          <script>
            let modalImages = [];
            let modalImageIndex = 0;

            function renderModalImage() {
              const imageName = modalImages[modalImageIndex] || "default.png";
              $("#zoomedProductImage").attr("src", `/uploads/${imageName}`);
              $("#imageCounter").text(`${modalImageIndex + 1} / ${modalImages.length || 1}`);
              $("#prevImageBtn").prop("disabled", modalImageIndex <= 0);
              $("#nextImageBtn").prop("disabled", modalImageIndex >= modalImages.length - 1);
            }

            $(document).on("click", ".product-thumb", function () {
              const imagesRaw = $(this).attr("data-images") || "[]";
              try {
                const parsedImages = JSON.parse(imagesRaw);
                modalImages = Array.isArray(parsedImages) && parsedImages.length > 0 ? parsedImages : ["default.png"];
              } catch (error) {
                modalImages = ["default.png"];
              }
              modalImageIndex = 0;
              renderModalImage();
              $("#productImageModal").modal("show");
            });

            $("#prevImageBtn").on("click", function () {
              if (modalImageIndex > 0) {
                modalImageIndex -= 1;
                renderModalImage();
              }
            });

            $("#nextImageBtn").on("click", function () {
              if (modalImageIndex < modalImages.length - 1) {
                modalImageIndex += 1;
                renderModalImage();
              }
            });
          </script>
</body>

</html>
