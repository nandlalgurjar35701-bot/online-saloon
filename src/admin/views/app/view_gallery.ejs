<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gallery Config</title>
  <%- include('../../partials/headlink.ejs') %>
</head>

<body>
  <%- include('../../partials/Header.ejs') %>
    <%- include("../../partials/sidebar.ejs") %>
      <%- include("../../partials/alertMsg.ejs") %>

      <main id="main" class="main">
        <div class="pagetitle">
          <h1><%- user.type %></h1>
          <nav>
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/">Home</a></li>
              <li class="breadcrumb-item active">Gallery Config</li>
            </ol>
          </nav>
        </div>

        <section class="section dashboard">
          <div class="row">
            <div class="col-lg-12">
              <div class="card">
                <div class="card-body">
                  <h5 class="card-title">Filter Gallery</h5>
                  <form class="row g-3" action="/view-gallery-config">
                    <div class="col-md-4">
                      <label>Title</label>
                      <input type="text" name="title" class="form-control" value="<%= query.title || '' %>"
                        placeholder="Enter title">
                    </div>
                    <div class="col-md-4">
                      <label>Category</label>
                      <input type="text" name="category" class="form-control" value="<%= query.category || '' %>"
                        placeholder="Enter category">
                    </div>
                    <div class="col-md-2">
                      <label>Status</label>
                      <select name="status" class="form-select">
                        <option value="" <%= query.status === '' || typeof query.status === 'undefined' ? 'selected' : '' %>>All</option>
                        <option value="true" <%= query.status === 'true' ? 'selected' : '' %>>Active</option>
                        <option value="false" <%= query.status === 'false' ? 'selected' : '' %>>Inactive</option>
                      </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                      <div>
                        <button type="submit" class="btn btn-primary">Submit</button>
                        <a href="/view-gallery-config" class="btn btn-secondary">Reset</a>
                      </div>
                    </div>
                  </form>
                </div>
              </div>

              <div class="card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Gallery Records</h5>
                    <a href="/gallery-config" class="btn btn-primary btn-sm">Add Gallery</a>
                  </div>
                  <div style="border-top: 1px solid #e9ecef; margin: 12px 0 14px 0;"></div>

                  <table class="table datatable">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Image</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Sort Order</th>
                        <th>Status</th>
                        <th>Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% let i = 0; %>
                        <% for (const item of data) { %>
                          <tr>
                            <td><%= ++i %></td>
                            <td>
                              <% const imageSrc = !item.image ? '/web/img/gallery-1.jpg' : (item.image.startsWith('http') || item.image.startsWith('/') ? item.image : (item.image.startsWith('gallery-') ? '/web/img/' + item.image : '/uploads/' + item.image)); %>
                                <img src="<%= imageSrc %>" alt="gallery" width="45" height="45"
                                  style="object-fit:cover;border-radius:8px;">
                            </td>
                            <td><%= item.title %></td>
                            <td><%= item.category || '-' %></td>
                            <td><%= Number(item.sortOrder || 0) %></td>
                            <td>
                              <% if (item.status) { %>
                                <span class="badge bg-success">Active</span>
                              <% } else { %>
                                <span class="badge bg-secondary">Inactive</span>
                              <% } %>
                            </td>
                            <td>
                              <a href="/gallery-config?id=<%= item._id %>" class="btn btn-info" data-bs-toggle="tooltip"
                                data-bs-placement="top" data-bs-title="Edit">
                                <i class="ri-edit-box-line"></i>
                              </a>
                              <a href="/delete-gallery-config?id=<%= item._id %>" class="btn btn-danger" data-bs-toggle="tooltip"
                                data-bs-placement="top" data-bs-title="Delete">
                                <i class="ri-delete-bin-5-line"></i>
                              </a>
                            </td>
                          </tr>
                        <% } %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <%- include("../../partials/script.ejs") %>
</body>

</html>
