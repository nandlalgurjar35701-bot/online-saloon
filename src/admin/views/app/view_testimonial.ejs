<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>View Testimonials</title>
  <%- include('../../partials/headlink.ejs') %>
</head>

<body>
  <%- include('../../partials/Header.ejs') %>
    <%- include("../../partials/sidebar.ejs") %>
      <%- include("../../partials/alertMsg.ejs") %>

      <main id="main" class="main">
        <div class="pagetitle">
          <h1><%- user.type %></h1>
          <nav>
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/admin/">Home</a></li>
              <li class="breadcrumb-item active">Testimonial Management</li>
            </ol>
          </nav>
        </div>

        <section class="section dashboard">
          <div class="row">
            <div class="col-lg-12">
              <div class="card">
                <div class="card-body">
                  <h5 class="card-title">Filter Testimonials</h5>
                  <form class="row g-3" action="/admin/view-testimonial">
                    <div class="col-md-4">
                      <label>Name</label>
                      <input type="text" name="name" class="form-control" value="<%= query.name || '' %>"
                        placeholder="Enter name">
                    </div>
                    <div class="col-md-4">
                      <label>Role</label>
                      <input type="text" name="role" class="form-control" value="<%= query.role || '' %>"
                        placeholder="Enter role">
                    </div>
                    <div class="col-md-2">
                      <label>Status</label>
                      <select name="status" class="form-select">
                        <option value="" <%= query.status === '' || typeof query.status === 'undefined' ? 'selected' : '' %>>All</option>
                        <option value="true" <%= query.status === 'true' ? 'selected' : '' %>>Active</option>
                        <option value="false" <%= query.status === 'false' ? 'selected' : '' %>>Inactive</option>
                      </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                      <div>
                        <button type="submit" class="btn btn-primary">Submit</button>
                        <a href="/admin/view-testimonial" class="btn btn-secondary">Reset</a>
                      </div>
                    </div>
                  </form>
                </div>
              </div>

              <div class="card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Testimonials</h5>
                    <a href="/admin/testimonial" class="btn btn-primary btn-sm">Add Testimonial</a>
                  </div>
                  <div style="border-top: 1px solid #e9ecef; margin: 12px 0 14px 0;"></div>

                  <table class="table datatable">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Rating</th>
                        <th>Sort Order</th>
                        <th>Status</th>
                        <th>Message</th>
                        <th>Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% let i = 0; %>
                        <% for (const item of data) { %>
                          <tr>
                            <td><%= ++i %></td>
                            <td>
                              <% const imageSrc = !item.image ? '/web/img/testimonial-1.jpg' : (item.image.startsWith('http') || item.image.startsWith('/') ? item.image : (item.image.startsWith('testimonial-') ? '/web/img/' + item.image : '/uploads/' + item.image)); %>
                                <img src="<%= imageSrc %>" alt="testimonial" width="45" height="45"
                                  style="object-fit:cover;border-radius:50%;">
                            </td>
                            <td><%= item.name %></td>
                            <td><%= item.role %></td>
                            <td><%= Number(item.rating || 5) %>/5</td>
                            <td><%= Number(item.sortOrder || 0) %></td>
                            <td>
                              <% if (item.status) { %>
                                <span class="badge bg-success">Active</span>
                              <% } else { %>
                                <span class="badge bg-secondary">Inactive</span>
                              <% } %>
                            </td>
                            <td>
                              <button type="button" class="btn btn-info view-btn" data-bs-toggle="modal"
                                data-bs-target="#messageModal" data-message="<%= encodeURIComponent(item.message || '') %>">
                                <i class="bi bi-eye"></i>
                              </button>
                            </td>
                            <td>
                              <a href="/admin/testimonial?id=<%= item._id %>" class="btn btn-info" data-bs-toggle="tooltip"
                                data-bs-placement="top" data-bs-title="Edit">
                                <i class="ri-edit-box-line"></i>
                              </a>
                              <a href="/admin/delete-testimonial?id=<%= item._id %>" class="btn btn-danger"
                                data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Delete">
                                <i class="ri-delete-bin-5-line"></i>
                              </a>
                            </td>
                          </tr>
                        <% } %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="messageModalLabel">Testimonial Message</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="testimonialMessagePreview">-</div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </div>
        </div>
      </div>

      <%- include("../../partials/script.ejs") %>
      <script>
        $('#messageModal').on('show.bs.modal', function (event) {
          const button = event.relatedTarget;
          const encodedMessage = button.getAttribute('data-message') || '';
          const message = encodedMessage ? decodeURIComponent(encodedMessage) : '-';
          document.getElementById('testimonialMessagePreview').textContent = message;
        });
      </script>
</body>

</html>

