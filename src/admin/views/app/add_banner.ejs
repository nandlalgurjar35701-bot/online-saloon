<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>add-faq-question</title>

  <%- include('../../partials/headlink.ejs') %>
</head>

<body>

  <%- include('../../partials/Header.ejs') %>
    <%- include("../../partials/sidebar.ejs") %>

      <main id="main" class="main">
        <div class="pagetitle">
          <h1>
            <%-user.type %>
          </h1>
          <nav>
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/">Home</a></li>
              <li class="breadcrumb-item active">Dashboard</li>
            </ol>
          </nav>
        </div><!-- End Page Title -->

        <section class="section dashboard">
          <div class="row">
            <div class="row">
              <div class="col-lg-12">
                <div class="card">
                  <div class="card-body">
                    <form action="/uplode-banner" method="POST" enctype="multipart/form-data">
                      <h5 class="card-title"><%- data._id ? "edit" : "Add" %> Frequent</h5>

                      <% if(data._id){%>
                        <input type="hidden" name="id" value="<%- data._id %>">
                        <%}%>
                          <div class="row mb-3">
                            <label for="inputText" class="col-sm-2 col-form-label">heading:</label>
                            <div class="col-sm-10">
                              <input type="text" name="heading" placeholder="Enter heading " class="form-control"
                                value="<%- data.heading ? data.heading : '' %>" required minlength="5">
                            </div>
                          </div>


                          <div class="row mb-3">
                            <label for="inputText" class="col-sm-2 col-form-label">title :</label>
                            <div class="col-sm-5">
                              <input type="text" name="title" placeholder="Enter title " class="form-control"
                                value="<%- data.title ? data.title : '' %>" required>
                            </div>

                            <div class="col-sm-5">
                              <input type="file" name="image" placeholder="uplode img " class="form-control" <%- data.id
                                ? 'required' : '' %>">
                              </select>
                            </div>
                          </div>

                          <div class="row mb-3">
                            <label for="inputText" class="col-sm-2 col-form-label">description:</label>
                            <div class="col-sm-10">
                              <input type="text" name="description" placeholder="Enter description "
                                class="form-control" value="<%- data.description ? data.description : '' %>" required
                                minlength="5">
                            </div>
                          </div>

                          <div class="row mb-3">

                            <div class="col-sm-10">
                              <button type="submit" class="btn btn-primary">Submit</button>
                            </div>
                          </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js"></script>

      <%- include("../../partials/script.ejs") %>
</body>

</html>