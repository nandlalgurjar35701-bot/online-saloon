<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>view-blog</title>
  <script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.8/dist/purify.min.js"></script>

  <%- include('../../partials/headlink.ejs') %>
</head>

<body>
  <%- include('../../partials/Header.ejs') %>
    <%- include("../../partials/sidebar.ejs") %>

      <main id="main" class="main">
        <div class="pagetitle">
          <h1><%-user.type %></h1>
          <nav>
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/">Home</a></li>
              <li class="breadcrumb-item active">Dashboard</li>
            </ol>
          </nav>
        </div>
        <!-- End Page Title -->
        <section class="section dashboard">
          <div class="row">
            <div class="row">
              <div class="col-lg-12">
                <div class="card">
                  <div class="card-body">
                    <h5 class="card-title">Filter</h5>

                    <!-- No Labels Form -->
                    <form class="row g-3" action="/view_blog">
                      <div class="col-md-3">
                        <label>Choose Category</label> <br>
                        <select id="inputState" name="Category" class="form-select">
                          <option selected="" value="">Choose Category</option>

                        </select>
                      </div>
                      <div class="col-md-3">
                        <label>Choose Writer Name</label> <br>
                        <select id="inputState" name="WriterName" class="form-select">
                          <option selected="" value="">select Writer Name</option>

                        </select>
                      </div>
                      <div class="col-md-3">
                        <label>Enter Title</label> <br>
                        <input type="text" name="Title" class="form-control" value="<%= query.Title ? query.Title:''%>"
                          placeholder="Enter Title">
                      </div>
                      <div class="col-md-3">
                        <div class="text-center">
                          <label></label> <br>
                          <button type="submit" class="btn btn-primary">Submit</button>
                          <a href="/view_blog"> <button type="button" class="btn btn-secondary">Reset</button></a>
                        </div>
                      </div>
                    </form>
                    <!-- End No Labels Form -->
                    <br>

                  </div>
                </div>
                <div class="card">
                  <div class="card-body">
                    <h5 class="card-title">Blog List</h5>

                    <!-- Table with stripped rows -->
                    <table class="table datatable">
                      <thead>
                        <tr>
                          <th scope="col">#</th>
                          <th scope="col">Title</th>
                          <th scope="col">Des.</th>
                          <th scope="col">Action</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% let i=0 %>
                          <% for( singleData of data) { %>
                            <tr>
                              <th scope="row">
                                <%= ++i %>
                              </th>
                              <td>
                                <%= singleData.title %>
                              </td>
                              <td>
                                <button type="button" class="btn btn-info" data-bs-toggle="modal"
                                  data-bs-target="#exampleModal" data-title="<%= singleData.title %>"
                                  onclick="showDescription(this)">
                                  <i class="bi bi-eye"></i>
                                </button>

                                <!-- ✅ Hidden CKEditor HTML (SAFE) -->
                                <div class="d-none blog-description">
                                  <%- singleData.description %>
                                </div>
                              </td>
                              <td>
                                <a href="/about?id=<%= singleData._id%>" class="btn btn-info"><i
                                    class="ri-edit-box-line" data-bs-toggle="tooltip" data-bs-placement="top"
                                    data-bs-title="Edit"></i></a>
                                <a href="/delete-About?id=<%= singleData._id%>" class="btn btn-danger"><i
                                    class="ri-delete-bin-5-line" data-bs-toggle="tooltip" data-bs-placement="top"
                                    data-bs-title="Delete"></i></a>
                              </td>
                            </tr>
                            <%}%>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

      </main>
      <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="exampleModalLabel">User Service Data</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="moduleDataAppend">
              ...
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </div>
        </div>
      </div>

      <!-- img model -->
      <div class="modal fade" id="imgModel" tabindex="-1" aria-labelledby="imgModel" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"
              style="width: 50px;"></button>
            <div class="modal-body" id="imgDataAppend">
              ...
            </div>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
      </div>

      <script>
        function showDescription(btn) {
          const title = btn.dataset.title;

          // ✅ Hidden div se CKEditor HTML uthao
          const dirtyHtml = btn
            .closest("td")
            .querySelector(".blog-description")
            .innerHTML;

          // 🔐 Client-side sanitize
          const cleanHtml = DOMPurify.sanitize(dirtyHtml, {
            ALLOWED_TAGS: [
              "p", "br", "b", "i", "strong", "em",
              "ul", "ol", "li",
              "h1", "h2", "h3", "h4",
              "img", "a", "blockquote"
            ],
            ALLOWED_ATTR: [
              "href", "src", "alt", "style", "target"
            ]
          });

          document.getElementById("exampleModalLabel").innerText = title;
          document.getElementById("moduleDataAppend").innerHTML = cleanHtml;
        }
      </script>




      <%- include("../../partials/script.ejs") %>
</body>

</html>