<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>view-Category</title>
  <%- include('../../partials/headlink.ejs') %>
</head>

<body>

  <%- include('../../partials/Header.ejs') %>
    <%- include("../../partials/sidebar.ejs") %>
      <%- include("../../partials/alertMsg") %>

        <main id="main" class="main">
          <div class="pagetitle">
            <h1><%-user.type %></h1>
            <nav>
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active">Dashboard</li>
              </ol>
            </nav>
          </div>
          <!-- End Page Title -->
          <section class="section dashboard">
            <div class="row">
              <div class="row">
                <div class="col-lg-12">
                  <div class="card">
                    <div class="card-body">
                      <h5 class="card-title">Filter</h5>

                      <!-- No Labels Form -->
                      <form class="row g-3" action="/view-category">
                        <div class="col-md-3">
                          <label>Choose City</label> <br>

                          <% if(query?.CategoryName!="" ){%>
                            <input type="text" name="CategoryName" class="form-control" value="<%=query?.CategoryName%>"
                              placeholder="CategoryName">
                            <%}else{%>
                              <input type="text" name="CategoryName" class="form-control" placeholder="CategoryName">
                              <%}%>
                        </div>

                        <div class="col-md-3">
                          <label>Choose Type</label> <br>
                          <select id="inputState" name="type" class="form-select">
                            <option selected="" value="">Choose For</option>
                            <option value="product" <%= (query.type=="product" || query.type=="0") ? 'selected' :'' %> >Product</option>
                            <option value="productpackage" <%= (query.type=="productpackage" || query.type=="1") ? 'selected' :'' %> >Product Package</option>
                            <!-- <option value="succes">succes</option> -->
                          </select>
                        </div>
                        <div class="col-md-3">
                          <label>status</label> <br>
                          <select id="inputState" name="status" class="form-select">
                            <% if(query.status!=undefined&&query.status!="" ){%>
                              <option selected="" value="all"> All </option>
                              <option value="">Choose Status</option>
                              <%}else{%>
                                <option selected="" value="">Choose Status</option>
                                <option value="all">All</option>
                                <%}%>
                          </select>
                        </div>

                        <div class="col-md-3">
                          <div class="text-center">
                            <label></label> <br>
                            <button type="submit" class="btn btn-primary">Submit</button>
                            <a href="/view-category"> <button type="button" class="btn btn-secondary">Reset</button></a>
                          </div>
                        </div>
                      </form>
                      <!-- End No Labels Form -->

                    </div>
                  </div>
                  <div class="card">
                    <div class="card-body">
                      <div class="d-flex justify-content-between align-items-center">
                        <% if(query?.id){ %>
                          <h5 class="card-title mb-0">Sub Category</h5>
                          <a href="/category?id=<%= query.id %>" class="btn btn-primary btn-sm">Add Sub Category</a>
                        <% } else { %>
                          <h5 class="card-title mb-0">Category</h5>
                          <a href="/category" class="btn btn-primary btn-sm">Add Category</a>
                        <% } %>
                      </div>
                      <div style="border-top: 1px solid #e9ecef; margin: 12px 0 14px 0;"></div>

                            <!-- Table with stripped rows -->
                            <table class="table datatable">
                              <thead>
                                <tr>
                                  <th>sr no</th>
                                  <th scope="col">Category Name</th>
                                  <th scope="col">description</th>
                                  <th scope="col">type</th>
                                  <th scope="col">images</th>

                                  <th scope="col">action</th>
                                </tr>
                              </thead>
                              <tbody>
                                <% let i=0 %>
                                  <% for (const category of data) { %>
                                    <tr>
                                      <td scope="row">
                                        <%= ++i %>
                                      </td>
                                      <td>
                                        <%= category.Name %>
                                      </td>
                                      <td>
                                        <% 
                                          const fullDescription = (category.description || "").trim();
                                          const shortDescription = fullDescription.length > 5
                                            ? `${fullDescription.slice(0, 5)}...`
                                            : (fullDescription || "-");
                                        %>
                                        <span><%= shortDescription %></span>
                                        <% if (fullDescription.length > 5) { %>
                                          <button type="button" class="btn btn-link btn-sm p-0 ms-1"
                                            data-bs-toggle="modal" data-bs-target="#descriptionModal"
                                            data-description="<%= encodeURIComponent(fullDescription) %>">
                                            Learn more
                                          </button>
                                        <% } %>
                                      </td>
                                      <td>
                                        <%= (category.type === "productpackage" || category.type === 1 || category.type === "1") ? "Product Package" : "Product" %>
                                      </td>
                                      <td>
                                        <% if(typeof category.image !="undefined" && category.image!="" ){%>
                                          <img class="rounded-circle" src="/uploads/<%= category.image %>" height="50px"
                                            width="50px" alt="">
                                          <!-- <img src="<%= user?.image%>" alt="image" class="rounded-circle" style="width: 40px; height: 50px;border-radius: 50%;"> -->
                                          <%}else{%>
                                            <img src="assets/img/profile-img.jpg" alt="Profile" height="50px"
                                              width="50px" class="rounded-circle">
                                            <%}%>
                                      </td>
                                      <td>
                                        <%if(category._doc.del=="view"){%>
                                          <a href="/category?EditId=<%= category._id%>" class="btn btn-info"
                                            data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Edit">
                                            <i class="ri-edit-box-line"></i></a>
                                          <a href="/view-category?id=<%= category._id%>" class="btn btn-success"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            data-bs-title="View Sub Category"><i class="bi bi-eye"></i></a>
                                          <a href="/category?id=<%= category._id%>" class="btn btn-success text-warning"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            data-bs-title="Add Sub Category"><i class="ri-file-add-line"></i></a>
                                          <%}else{%>
                                            <a href="/category?EditId=<%= category._id%>" class="btn btn-info"
                                              data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Edit"><i
                                                class="ri-edit-box-line"></i></a>
                                            <a href="/delete-category?id=<%= category._id%>" class="btn btn-danger"
                                              data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Delete">
                                              <i class="ri-delete-bin-5-line"></i>
                                            </a>
                                            <% if(!category.parent_Name){ %>
                                              <a href="/category?id=<%= category._id%>" class="btn btn-success text-warning"
                                                data-bs-toggle="tooltip" data-bs-placement="top"
                                                data-bs-title="Add Sub Category"><i class="ri-file-add-line"></i></a>
                                              <%}%>
                                                <%}%>
                                      </td>
                                    </tr>
                                    <%}%>
                              </tbody>
                            </table>
                            <!-- End Table with stripped rows -->
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>
        </main>
        <div class="modal fade" id="descriptionModal" tabindex="-1" aria-labelledby="descriptionModalLabel"
          aria-hidden="true">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="descriptionModalLabel">Category Description</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body" id="descriptionModalBody">-</div>
            </div>
          </div>
        </div>
        <%- include("../../partials/script.ejs") %>
          <script>
            const descriptionModal = document.getElementById("descriptionModal");
            if (descriptionModal) {
              descriptionModal.addEventListener("show.bs.modal", function (event) {
                const trigger = event.relatedTarget;
                const encodedDescription = trigger?.getAttribute("data-description") || "";
                const decodedDescription = encodedDescription ? decodeURIComponent(encodedDescription) : "-";
                const body = document.getElementById("descriptionModalBody");
                if (body) body.textContent = decodedDescription || "-";
              });
            }
          </script>
</body>

</html>
