<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>
<body>
    <div id="spinner"
        class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>

    <%- include('./partials/header.ejs') %>

    <div class="container-fluid bg-breadcrumb py-5">
        <div class="container text-center py-5">
            <h3 class="text-white display-5 mb-2">My Cart</h3>
        </div>
    </div>

    <div class="container py-5">
        <div id="cartContainer" class="row g-4"></div>
    </div>

    <%- include('./partials/footerlink.ejs') %>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        (function () {
            const token = localStorage.getItem("auth") || localStorage.getItem("token") || localStorage.getItem("accessToken");
            const razorpayKey = "<%= razorpayKey || '' %>";
            const container = document.getElementById("cartContainer");

            if (!token) {
                alert("Please login first.");
                window.location.href = "/";
                return;
            }

            const authHeaders = () => ({ Authorization: `Bearer ${token}` });
            const timeslots = [
                "09:00 AM", "10:00 AM", "11:00 AM", "12:00 PM",
                "01:00 PM", "02:00 PM", "03:00 PM", "04:00 PM",
                "05:00 PM", "06:00 PM", "07:00 PM"
            ];

            const emitCartCount = (data) => {
                const allQty = (Array.isArray(data) ? data : []).reduce((sum, saloonEntry) => {
                    const cartItems = Array.isArray(saloonEntry.cart) ? saloonEntry.cart : [];
                    return sum + cartItems.reduce((s, item) => s + Number(item?.cartdata?.quantity || 0), 0);
                }, 0);
                window.dispatchEvent(new CustomEvent("cart:updated", { detail: { count: allQty } }));
            };

            const renderEmpty = (message) => {
                container.innerHTML = `<div class="col-12 text-center"><p class="mb-0">${message}</p></div>`;
                emitCartCount([]);
            };

            const normalizeImage = (image) => {
                if (Array.isArray(image) && image.length) return `/uploads/${image[0]}`;
                if (typeof image === "string" && image) return image.startsWith("http") ? image : `/uploads/${image}`;
                return "/web/img/services-1.jpg";
            };

            const saveSchedule = async (saloonId, dateValue, slotValue) => {
                const response = await fetch(`/Schedule-your-visit?saloonId=${saloonId}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", ...authHeaders() },
                    body: JSON.stringify({ date: dateValue, timeslot: slotValue }),
                });
                return response.json();
            };

            const placeOfflineOrder = async (cartId) => {
                const response = await fetch(`/order?cartId=${cartId}&paymentMode=offline`, {
                    method: "GET",
                    headers: authHeaders(),
                });
                return response.json();
            };

            const createPaymentOrder = async (amount) => {
                const response = await fetch("/create/orderId", {
                    method: "POST",
                    headers: { "Content-Type": "application/json", ...authHeaders() },
                    body: JSON.stringify({ amount }),
                });
                return response.json();
            };

            const verifyPayment = async (paymentDocId, responseObj) => {
                const response = await fetch(`/api/payment/verify?orderId=${paymentDocId}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", ...authHeaders() },
                    body: JSON.stringify({ response: responseObj }),
                });
                return response.json();
            };

            const placeOnlineOrder = async (cartId, paymentDocId) => {
                const response = await fetch(`/order?cartId=${cartId}&PaymentId=${paymentDocId}&paymentMode=online`, {
                    method: "GET",
                    headers: authHeaders(),
                });
                return response.json();
            };

            const openRazorpay = ({ amount, orderId, paymentDocId, cartId }) => {
                return new Promise((resolve, reject) => {
                    if (!razorpayKey) {
                        reject(new Error("Razorpay key missing."));
                        return;
                    }
                    const options = {
                        key: razorpayKey,
                        amount: Number(amount || 0) * 100,
                        currency: "INR",
                        name: "Salon Checkout",
                        description: "Service Booking",
                        order_id: orderId,
                        handler: async function (responseObj) {
                            try {
                                const verifyResult = await verifyPayment(paymentDocId, responseObj);
                                if (!verifyResult?.status) {
                                    reject(new Error(verifyResult?.message || "Payment verification failed."));
                                    return;
                                }
                                const orderResult = await placeOnlineOrder(cartId, paymentDocId);
                                if (!orderResult?.status) {
                                    reject(new Error(orderResult?.message || "Order placement failed."));
                                    return;
                                }
                                resolve(orderResult);
                            } catch (error) {
                                reject(error);
                            }
                        },
                        theme: { color: "#0d6efd" },
                    };
                    const rzp = new Razorpay(options);
                    rzp.on("payment.failed", function () {
                        reject(new Error("Payment failed."));
                    });
                    rzp.open();
                });
            };

            const loadCart = async () => {
                try {
                    const response = await fetch("/get-cart", { headers: authHeaders() });
                    const result = await response.json();
                    if (!(response.ok && result?.status) || !Array.isArray(result.data) || result.data.length === 0) {
                        renderEmpty(result?.message || "Cart is empty.");
                        return;
                    }

                    const data = result.data;
                    emitCartCount(data);

                    container.innerHTML = data.map((saloonEntry, idx) => {
                        const cartItems = Array.isArray(saloonEntry.cart) ? saloonEntry.cart : [];
                        const cartId = cartItems?.[0]?._id || "";
                        const saloonId = saloonEntry?._id || "";
                        const totalAmount = Number(cartItems?.[0]?.totalamount || 0);
                        const rows = cartItems.map((entry) => {
                            const c = entry.cartdata || {};
                            return `
                                <tr>
                                    <td>${c.ServiceName || "-"}</td>
                                    <td>${Number(c.quantity || 0)}</td>
                                    <td>Rs. ${Number(c.ServicePrice || 0)}</td>
                                    <td>Rs. ${Number(c.Amount || 0)}</td>
                                </tr>
                            `;
                        }).join("");

                        return `
                            <div class="col-12">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-3">
                                            <img src="${normalizeImage(saloonEntry?.image)}" style="width:72px;height:72px;object-fit:cover;border-radius:8px;" alt="store">
                                            <div class="ms-3">
                                                <h5 class="mb-1">${saloonEntry?.storeName || "Salon"}</h5>
                                                <p class="text-muted mb-0">${saloonEntry?.location?.city || ""} ${saloonEntry?.location?.state || ""}</p>
                                            </div>
                                        </div>

                                        <div class="table-responsive">
                                            <table class="table table-sm align-middle">
                                                <thead>
                                                    <tr>
                                                        <th>Service</th>
                                                        <th>Qty</th>
                                                        <th>Unit Price</th>
                                                        <th>Amount</th>
                                                    </tr>
                                                </thead>
                                                <tbody>${rows}</tbody>
                                            </table>
                                        </div>

                                        <div class="row g-3 mt-2">
                                            <div class="col-md-3">
                                                <label class="form-label">Visit Date</label>
                                                <input type="date" class="form-control" id="date_${idx}">
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label">Time Slot</label>
                                                <select class="form-select" id="slot_${idx}">
                                                    <option value="">Select Slot</option>
                                                    ${timeslots.map((slot) => `<option value="${slot}">${slot}</option>`).join("")}
                                                </select>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label d-block">Payment Mode</label>
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="paymentMode_${idx}" id="online_${idx}" value="online" checked>
                                                    <label class="form-check-label" for="online_${idx}">Online</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="paymentMode_${idx}" id="offline_${idx}" value="offline">
                                                    <label class="form-check-label" for="offline_${idx}">Offline (Store)</label>
                                                </div>
                                            </div>
                                            <div class="col-md-3 d-flex align-items-end justify-content-between">
                                                <h5 class="mb-0">Total: Rs. ${totalAmount}</h5>
                                            </div>
                                        </div>

                                        <div class="mt-3 d-flex gap-2">
                                            <button class="btn btn-outline-primary btn-sm schedule-btn"
                                                data-saloon-id="${saloonId}" data-date-id="date_${idx}" data-slot-id="slot_${idx}">
                                                Save Date & Slot
                                            </button>
                                            <button class="btn btn-primary btn-sm checkout-btn"
                                                data-cart-id="${cartId}" data-saloon-id="${saloonId}"
                                                data-date-id="date_${idx}" data-slot-id="slot_${idx}"
                                                data-payment-name="paymentMode_${idx}" data-total="${totalAmount}">
                                                Checkout
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }).join("");

                    bindActions();
                } catch (error) {
                    renderEmpty("Unable to load cart.");
                }
            };

            const bindActions = () => {
                const scheduleButtons = Array.from(document.querySelectorAll(".schedule-btn"));
                const checkoutButtons = Array.from(document.querySelectorAll(".checkout-btn"));

                scheduleButtons.forEach((btn) => {
                    btn.addEventListener("click", async () => {
                        const saloonId = btn.getAttribute("data-saloon-id");
                        const dateValue = document.getElementById(btn.getAttribute("data-date-id"))?.value || "";
                        const slotValue = document.getElementById(btn.getAttribute("data-slot-id"))?.value || "";
                        if (!dateValue || !slotValue) {
                            alert("Please select date and time slot.");
                            return;
                        }
                        btn.disabled = true;
                        try {
                            const result = await saveSchedule(saloonId, dateValue, slotValue);
                            alert(result?.message || "Schedule updated.");
                        } catch (error) {
                            alert("Unable to save schedule.");
                        } finally {
                            btn.disabled = false;
                        }
                    });
                });

                checkoutButtons.forEach((btn) => {
                    btn.addEventListener("click", async () => {
                        const cartId = btn.getAttribute("data-cart-id");
                        const saloonId = btn.getAttribute("data-saloon-id");
                        const dateValue = document.getElementById(btn.getAttribute("data-date-id"))?.value || "";
                        const slotValue = document.getElementById(btn.getAttribute("data-slot-id"))?.value || "";
                        const paymentModeName = btn.getAttribute("data-payment-name");
                        const selectedPayment = document.querySelector(`input[name="${paymentModeName}"]:checked`)?.value || "online";
                        const total = Number(btn.getAttribute("data-total") || 0);

                        if (!dateValue || !slotValue) {
                            alert("Please select date and time slot before payment.");
                            return;
                        }
                        btn.disabled = true;
                        try {
                            const scheduleResult = await saveSchedule(saloonId, dateValue, slotValue);
                            if (!scheduleResult?.status) {
                                alert(scheduleResult?.message || "Unable to save schedule.");
                                return;
                            }

                            if (selectedPayment === "offline") {
                                const offlineOrder = await placeOfflineOrder(cartId);
                                if (!offlineOrder?.status) {
                                    alert(offlineOrder?.message || "Unable to place offline order.");
                                    return;
                                }
                                alert(offlineOrder?.message || "Order placed successfully.");
                                await loadCart();
                                return;
                            }

                            const paymentOrder = await createPaymentOrder(total);
                            if (!paymentOrder?.status || !Array.isArray(paymentOrder.data) || !paymentOrder.data[0]) {
                                alert(paymentOrder?.message || "Unable to initiate payment.");
                                return;
                            }
                            const paymentDoc = paymentOrder.data[0];
                            await openRazorpay({
                                amount: total,
                                orderId: paymentDoc?.orderData?.id,
                                paymentDocId: paymentDoc?._id,
                                cartId,
                            });
                            alert("Payment successful and order placed.");
                            await loadCart();
                        } catch (error) {
                            alert(error?.message || "Checkout failed.");
                        } finally {
                            btn.disabled = false;
                        }
                    });
                });
            };

            loadCart();
        })();
    </script>
</body>
</html>
