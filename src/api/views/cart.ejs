<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>
<style>
    @media (min-width: 992px) {
        .cart-left-col {
            width: 60%;
        }

        .cart-right-col {
            width: 40%;
        }
    }
</style>
<body>
    <div id="spinner"
        class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>

    <%- include('./partials/header.ejs') %>

    <div class="container-fluid bg-breadcrumb py-5">
        <div class="container text-center py-5">
            <h3 class="text-white display-5 mb-2">My Cart</h3>
        </div>
    </div>

    <div class="container py-5">
        <div class="row g-4">
            <div class="col-12 cart-left-col" id="cartListContainer"></div>
            <div class="col-12 cart-right-col">
                <div class="card border-0 shadow-sm position-sticky" style="top: 110px;">
                    <div class="card-body">
                        <h5 class="mb-3">Cart Summary</h5>
                        <!-- Store selection removed as cart is no longer saloon-based -->
                        <div class="mb-3 d-none">
                            <label class="form-label">Select Store</label>
                            <select class="form-select" id="summaryStoreSelect"></select>
                        </div>
                        <div class="d-flex justify-content-between mb-2 d-none">
                            <span class="text-muted">Stores</span>
                            <strong id="summaryStores">0</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Total Items</span>
                            <strong id="summaryItems">0</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Total Amount</span>
                            <strong id="summaryAmount">Rs. 0</strong>
                        </div>
                        <hr>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label">Visit Date</label>
                                <input type="date" class="form-control" id="summaryDate">
                            </div>
                            <div class="col-6">
                                <label class="form-label">Time Slot</label>
                                <select class="form-select" id="summarySlot"></select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label d-block">Payment Mode</label>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="summaryPaymentMode" id="summaryOnline" value="online" checked>
                                <label class="form-check-label" for="summaryOnline">Online <span class="badge bg-success ms-1">Recommended</span></label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="summaryPaymentMode" id="summaryOffline" value="offline">
                                <label class="form-check-label" for="summaryOffline">Offline (Store)</label>
                            </div>
                        </div>
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-primary" id="summarySaveDraftBtn">Save Draft</button>
                            <button class="btn btn-primary" id="summaryCheckoutBtn">Checkout</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('./partials/footerlink.ejs') %>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        (function () {
            const token = localStorage.getItem("auth") || localStorage.getItem("token") || localStorage.getItem("accessToken");
            const razorpayKey = "<%= razorpayKey || '' %>";
            const listContainer = document.getElementById("cartListContainer");
            const summaryStores = document.getElementById("summaryStores");
            const summaryItems = document.getElementById("summaryItems");
            const summaryAmount = document.getElementById("summaryAmount");
            const summaryStoreSelect = document.getElementById("summaryStoreSelect");
            const summaryDate = document.getElementById("summaryDate");
            const summarySlot = document.getElementById("summarySlot");
            const summarySaveDraftBtn = document.getElementById("summarySaveDraftBtn");
            const summaryCheckoutBtn = document.getElementById("summaryCheckoutBtn");

            let cartData = [];
            const scheduleDraftByStore = {};

            if (!token) {
                alert("Please login first.");
                window.location.href = "/";
                return;
            }

            const authHeaders = () => ({ 
                Authorization: `Bearer ${token}`
            });
            const timeslots = [
                "09:00 AM", "10:00 AM", "11:00 AM", "12:00 PM",
                "01:00 PM", "02:00 PM", "03:00 PM", "04:00 PM",
                "05:00 PM", "06:00 PM", "07:00 PM"
            ];

            const emitCartCount = (data) => {
                const cartDoc = data?.[0] || {};
                const items = Array.isArray(cartDoc.items) ? cartDoc.items : [];
                const allQty = items.reduce((s, item) => s + Number(item?.quantity || 0), 0);
                window.dispatchEvent(new CustomEvent("cart:updated", { detail: { count: allQty } }));
            };

            const setSummaryEnabled = (enabled) => {
                if (summaryStoreSelect) summaryStoreSelect.disabled = !enabled;
                if (summaryDate) summaryDate.disabled = !enabled;
                if (summarySlot) summarySlot.disabled = !enabled;
                if (summarySaveDraftBtn) summarySaveDraftBtn.disabled = !enabled;
                if (summaryCheckoutBtn) summaryCheckoutBtn.disabled = !enabled;
                const paymentInputs = document.querySelectorAll('input[name="summaryPaymentMode"]');
                paymentInputs.forEach((input) => input.disabled = !enabled);
            };

            const populateSlots = () => {
                if (!summarySlot) return;
                summarySlot.innerHTML = `<option value="">Select Slot</option>${timeslots.map((slot) => `<option value="${slot}">${slot}</option>`).join("")}`;
            };

            const renderEmpty = (message) => {
                listContainer.innerHTML = `<div class="card border-0 shadow-sm"><div class="card-body text-center"><p class="mb-0">${message}</p></div></div>`;
                if (summaryStores) summaryStores.textContent = "0";
                if (summaryItems) summaryItems.textContent = "0";
                if (summaryAmount) summaryAmount.textContent = "Rs. 0";
                if (summaryStoreSelect) summaryStoreSelect.innerHTML = `<option value="">No Store</option>`;
                if (summaryDate) summaryDate.value = "";
                populateSlots();
                setSummaryEnabled(false);
                emitCartCount([]);
            };

            const normalizeServiceImage = (image) => {
                if (Array.isArray(image) && image.length) {
                    const first = image[0];
                    return String(first).startsWith("http") ? first : `/uploads/${first}`;
                }
                if (typeof image === "string" && image) return image.startsWith("http") ? image : `/uploads/${image}`;
                return "/web/img/services-1.jpg";
            };

            const saveSchedule = async (saloonId, dateValue, slotValue) => {
                const response = await fetch(`/Schedule-your-visit?saloonId=${saloonId}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", ...authHeaders() },
                    body: JSON.stringify({ date: dateValue, timeslot: slotValue }),
                });
                return response.json();
            };

            const placeOfflineOrder = async (cartId) => {
                const response = await fetch(`/order?cartId=${cartId}&paymentMode=offline`, {
                    method: "GET",
                    headers: authHeaders(),
                });
                return response.json();
            };

            const createPaymentOrder = async (amount) => {
                const response = await fetch("/create/orderId", {
                    method: "POST",
                    headers: { "Content-Type": "application/json", ...authHeaders() },
                    body: JSON.stringify({ amount }),
                });
                return response.json();
            };

            const verifyPayment = async (paymentDocId, responseObj) => {
                const response = await fetch(`/api/payment/verify?orderId=${paymentDocId}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", ...authHeaders() },
                    body: JSON.stringify({ response: responseObj }),
                });
                return response.json();
            };

            const placeOnlineOrder = async (cartId, paymentDocId) => {
                const response = await fetch(`/order?cartId=${cartId}&PaymentId=${paymentDocId}&paymentMode=online`, {
                    method: "GET",
                    headers: authHeaders(),
                });
                return response.json();
            };

            const openRazorpay = ({ amount, orderId, paymentDocId, cartId }) => {
                return new Promise((resolve, reject) => {
                    if (!razorpayKey) {
                        reject(new Error("Razorpay key missing."));
                        return;
                    }
                    const options = {
                        key: razorpayKey,
                        amount: Number(amount || 0) * 100,
                        currency: "INR",
                        name: "Salon Checkout",
                        description: "Service Booking",
                        order_id: orderId,
                        handler: async function (responseObj) {
                            try {
                                const verifyResult = await verifyPayment(paymentDocId, responseObj);
                                if (!verifyResult?.status) {
                                    reject(new Error(verifyResult?.message || "Payment verification failed."));
                                    return;
                                }
                                const orderResult = await placeOnlineOrder(cartId, paymentDocId);
                                if (!orderResult?.status) {
                                    reject(new Error(orderResult?.message || "Order placement failed."));
                                    return;
                                }
                                resolve(orderResult);
                            } catch (error) {
                                reject(error);
                            }
                        },
                        theme: { color: "#0d6efd" },
                    };
                    const rzp = new Razorpay(options);
                    rzp.on("payment.failed", function () {
                        reject(new Error("Payment failed."));
                    });
                    rzp.open();
                });
            };

            const loadCart = async () => {
                try {
                    const response = await fetch("/get-cart", { headers: authHeaders() });
                    const result = await response.json();
                    if (!(response.ok && result?.status) || !Array.isArray(result.data) || result.data.length === 0) {
                        renderEmpty(result?.message || "Cart is empty.");
                        return;
                    }

                    const data = result.data;
                    cartData = data;
                    emitCartCount(data);

                    const cartDoc = data[0];
                    const items = Array.isArray(cartDoc.items) ? cartDoc.items : [];
                    const totalItems = items.reduce((s, entry) => s + Number(entry?.quantity || 0), 0);
                    const totalAmountAll = Number(cartDoc.totalamount || 0);

                    if (summaryItems) summaryItems.textContent = String(totalItems);
                    if (summaryAmount) summaryAmount.textContent = `Rs. ${totalAmountAll}`;

                    const rows = items.map((c) => {
                        const serviceImage = normalizeServiceImage(c.image);
                        return `
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="${serviceImage}" alt="service" style="width:44px;height:44px;object-fit:cover;border-radius:8px;">
                                        <span class="ms-2">${c.ServiceName || "-"}</span>
                                    </div>
                                </td>
                                <td>${Number(c.quantity || 0)}</td>
                                <td>Rs. ${Number(c.ServicePrice || 0)}</td>
                                <td>Rs. ${Number(c.Amount || 0)}</td>
                            </tr>
                        `;
                    }).join("");

                    listContainer.innerHTML = `
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h5 class="mb-3">Cart Items</h5>
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>Service</th>
                                                <th>Qty</th>
                                                <th>Unit Price</th>
                                                <th>Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>${rows}</tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    `;
                    bindSummaryControls();
                } catch (error) {
                    renderEmpty("Unable to load cart.");
                }
            };

            const updateSummaryForSelectedStore = () => {
                const cartDoc = cartData?.[0] || {};
                const items = Array.isArray(cartDoc.items) ? cartDoc.items : [];
                const selectedItems = items.reduce((sum, entry) => sum + Number(entry?.quantity || 0), 0);
                const selectedAmount = Number(cartDoc.totalamount || 0);
                if (summaryItems) summaryItems.textContent = String(selectedItems);
                if (summaryAmount) summaryAmount.textContent = `Rs. ${selectedAmount}`;
            };

            const bindSummaryControls = () => {
                populateSlots();
                if (cartData.length > 0) {
                    setSummaryEnabled(true);
                } else {
                    setSummaryEnabled(false);
                }

                const applyDraftToUi = () => {
                    const cartDoc = cartData?.[0] || {};
                    const cartId = String(cartDoc?._id || "");
                    const draft = scheduleDraftByStore[cartId] || {};
                    if (summaryDate) summaryDate.value = draft.date || "";
                    if (summarySlot) summarySlot.value = draft.slot || "";
                    const mode = draft.paymentMode || "online";
                    const paymentRadio = document.querySelector(`input[name="summaryPaymentMode"][value="${mode}"]`);
                    if (paymentRadio) paymentRadio.checked = true;
                    updateSummaryForSelectedStore();
                };

                summarySaveDraftBtn?.addEventListener("click", async () => {
                    const cartDoc = cartData?.[0] || {};
                    const cartId = String(cartDoc?._id || "");
                    const dateValue = summaryDate?.value || "";
                    const slotValue = summarySlot?.value || "";
                    const paymentMode = document.querySelector('input[name="summaryPaymentMode"]:checked')?.value || "online";
                    
                    if (!cartId || !dateValue || !slotValue) {
                        alert("Please select date and time slot.");
                        return;
                    }
                    summarySaveDraftBtn.disabled = true;
                    try {
                        // Pass cartId instead of saloonId if needed, or modify saveSchedule
                        const result = await saveSchedule(cartId, dateValue, slotValue);
                        if (!result?.status) {
                            alert(result?.message || "Unable to save schedule.");
                            return;
                        }
                        scheduleDraftByStore[cartId] = { date: dateValue, slot: slotValue, paymentMode };
                        alert(result?.message || "Draft saved.");
                    } catch (error) {
                        alert("Unable to save draft.");
                    } finally {
                        summarySaveDraftBtn.disabled = false;
                    }
                });

                summaryCheckoutBtn?.addEventListener("click", async () => {
                    const cartDoc = cartData?.[0] || {};
                    const cartId = String(cartDoc?._id || "");
                    const total = Number(cartDoc?.totalamount || 0);
                    const dateValue = summaryDate?.value || "";
                    const slotValue = summarySlot?.value || "";
                    const selectedPayment = document.querySelector('input[name="summaryPaymentMode"]:checked')?.value || "online";

                    if (!cartId) {
                        alert("Your cart is empty.");
                        return;
                    }
                    if (!dateValue || !slotValue) {
                        alert("Please select date and time slot before payment.");
                        return;
                    }

                    summaryCheckoutBtn.disabled = true;
                    try {
                        const scheduleResult = await saveSchedule(cartId, dateValue, slotValue);
                        if (!scheduleResult?.status) {
                            alert(scheduleResult?.message || "Unable to save schedule.");
                            return;
                        }

                        if (selectedPayment === "offline") {
                            const offlineOrder = await placeOfflineOrder(cartId);
                            if (!offlineOrder?.status) {
                                alert(offlineOrder?.message || "Unable to place offline order.");
                                return;
                            }
                            alert(offlineOrder?.message || "Order placed successfully.");
                            await loadCart();
                            return;
                        }

                        const paymentOrder = await createPaymentOrder(total);
                        if (!paymentOrder?.status || !Array.isArray(paymentOrder.data) || !paymentOrder.data[0]) {
                            alert(paymentOrder?.message || "Unable to initiate payment.");
                            return;
                        }
                        const paymentDoc = paymentOrder.data[0];
                        await openRazorpay({
                            amount: total,
                            orderId: paymentDoc?.orderData?.id,
                            paymentDocId: paymentDoc?._id,
                            cartId,
                        });
                        alert("Payment successful and order placed.");
                        await loadCart();
                    } catch (error) {
                        alert(error?.message || "Checkout failed.");
                    } finally {
                        summaryCheckoutBtn.disabled = false;
                    }
                });

                applyDraftToUi();
            };

            loadCart();
        })();
    </script>
</body>
</html>
