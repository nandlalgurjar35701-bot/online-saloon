<!DOCTYPE html>
<html lang="en">
<%- include("./partials/head.ejs") %>
<body>
    <div id="spinner" class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>

    <%- include("./partials/header.ejs") %>

    <div class="container-fluid bg-breadcrumb py-5">
        <div class="container text-center py-5">
            <h3 class="text-white display-3 mb-4">Book Appointment</h3>
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active text-white">Appointment</li>
            </ol>
        </div>
    </div>

    <div class="container-fluid appointment py-5">
        <div class="container py-5">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6">
                    <div class="appointment-form p-5">
                        <p class="fs-4 text-uppercase text-primary">Get In Touch</p>
                        <h1 class="display-5 mb-4 text-white">Schedule Your Visit</h1>
                        <form>
                            <div class="row gy-3 gx-4">
                                <div class="col-lg-6"><input type="text" class="form-control py-3 border-white bg-transparent text-white" placeholder="Name"></div>
                                <div class="col-lg-6"><input type="email" class="form-control py-3 border-white bg-transparent text-white" placeholder="Email"></div>
                                <div class="col-lg-6"><input type="text" class="form-control py-3 border-white bg-transparent text-white" placeholder="Phone"></div>
                                <div class="col-lg-6"><input type="date" class="form-control py-3 border-white bg-transparent text-white"></div>
                                <div class="col-lg-12"><textarea class="form-control border-white bg-transparent text-white" rows="4" placeholder="Message"></textarea></div>
                                <div class="col-lg-12"><button type="button" class="btn btn-primary w-100 py-3 px-5">Submit</button></div>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="appointment-time p-5">
                        <h1 class="display-5 mb-4">Opening Hours</h1>
                        <p class="fs-5 text-white mb-2">Mon - Fri: 09:00 AM - 09:00 PM</p>
                        <p class="fs-5 text-white mb-2">Saturday: 09:00 AM - 08:00 PM</p>
                        <p class="fs-5 text-white mb-2">Sunday: 10:00 AM - 06:00 PM</p>
                        <hr class="text-white">
                        <p class="fs-5 text-white mb-0">Call us: +91 98765 43210</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include("./partials/footerlink.ejs") %>
</body>
</html>
