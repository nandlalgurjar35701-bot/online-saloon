<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>
<body>
    <div id="spinner"
        class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>

    <%- include('./partials/header.ejs') %>

    <div class="container-fluid bg-breadcrumb py-5">
        <div class="container text-center py-5">
            <h3 class="text-white display-5 mb-2">My Wishlist</h3>
        </div>
    </div>

    <div class="container py-5">
        <div id="wishlistContainer" class="row g-4"></div>
    </div>

    <%- include('./partials/footerlink.ejs') %>

    <script>
        (function () {
            const token = localStorage.getItem("auth") || localStorage.getItem("token") || localStorage.getItem("accessToken");
            if (!token) {
                alert("Please login first.");
                window.location.href = "/";
                return;
            }

            const container = document.getElementById("wishlistContainer");
            const getHeaders = () => ({ Authorization: `Bearer ${token}` });
            const imageUrl = (item) => {
                const image = item?.result?.image;
                if (Array.isArray(image) && image.length) {
                    const first = String(image[0] || "");
                    if (!first) return "/web/img/services-1.jpg";
                    return first.startsWith("http") || first.startsWith("/") ? first : `/uploads/${first}`;
                }
                if (typeof image === "string" && image) {
                    return image.startsWith("http") || image.startsWith("/") ? image : `/uploads/${image}`;
                }
                return "/web/img/services-1.jpg";
            };

            const renderEmpty = (message) => {
                container.innerHTML = `<div class="col-12 text-center"><p class="mb-0">${message}</p></div>`;
            };

            const showMessage = (message) => {
                if (!message) return;
                alert(message);
            };

            const getSaloonId = (item) => {
                const fromProduct = item?.result?.saloonStore;
                if (typeof fromProduct === "string") return fromProduct;
                if (fromProduct && typeof fromProduct === "object" && fromProduct._id) return String(fromProduct._id);
                if (item?.store?._id) return String(item.store._id);
                return "";
            };

            const bindActions = () => {
                const addCartButtons = Array.from(container.querySelectorAll(".wishlist-add-cart"));
                const wishlistButtons = Array.from(container.querySelectorAll(".wishlist-toggle"));

                addCartButtons.forEach((button) => {
                    button.addEventListener("click", async () => {
                        const serviceId = button.getAttribute("data-product-id");
                        const saloonId = button.getAttribute("data-saloon-id");
                        if (!serviceId || !saloonId) {
                            showMessage("Invalid item details.");
                            return;
                        }
                        button.disabled = true;
                        try {
                            const response = await fetch(`/add-cart?serviceId=${serviceId}&saloonId=${saloonId}`, {
                                method: "GET",
                                headers: getHeaders(),
                            });
                            const result = await response.json();
                            if (response.ok && result?.status) {
                                showMessage("Added to cart.");
                            } else {
                                showMessage(result?.message || "Unable to add to cart.");
                            }
                        } catch (error) {
                            showMessage("Unable to add to cart right now.");
                        } finally {
                            button.disabled = false;
                        }
                    });
                });

                wishlistButtons.forEach((button) => {
                    button.addEventListener("click", async () => {
                        const productId = button.getAttribute("data-product-id");
                        if (!productId) {
                            showMessage("Invalid wishlist item.");
                            return;
                        }
                        button.disabled = true;
                        try {
                            const response = await fetch(`/wishlist?id=${productId}&type=product`, {
                                method: "GET",
                                headers: getHeaders(),
                            });
                            const result = await response.json();
                            if (response.ok && result?.status) {
                                await loadWishlist();
                            } else {
                                showMessage(result?.message || "Unable to update wishlist.");
                            }
                        } catch (error) {
                            showMessage("Unable to update wishlist right now.");
                        } finally {
                            button.disabled = false;
                        }
                    });
                });
            };

            const loadWishlist = async () => {
                try {
                    const response = await fetch("/get-wishlist?type=product", {
                        headers: getHeaders(),
                    });
                    const result = await response.json();
                    if (!(response.ok && result?.status) || !Array.isArray(result.data) || result.data.length === 0) {
                        renderEmpty(result?.message || "No wishlist data found.");
                        return;
                    }

                    container.innerHTML = result.data.map((item) => `
                        <div class="col-md-6 col-lg-4">
                            <div class="card border-0 shadow-sm h-100">
                                <img src="${imageUrl(item)}" class="card-img-top" style="height: 220px; object-fit: cover;" alt="Salon">
                                <div class="card-body">
                                    <h5 class="card-title mb-2">${item?.result?.ServiceName || "Service"}</h5>
                                    <p class="card-text text-muted mb-2">${item?.result?.description || ""}</p>
                                    <p class="card-text mb-1"><strong>Price:</strong> Rs. ${Number(item?.result?.ServicePrice || 0)}</p>
                                    <p class="card-text text-muted mb-0">${item?.store?.storeName || ""}</p>
                                    <div class="d-flex align-items-center justify-content-between mt-3">
                                        <button
                                            type="button"
                                            class="btn btn-primary btn-sm wishlist-add-cart"
                                            data-product-id="${item?.result?._id || ""}"
                                            data-saloon-id="${getSaloonId(item)}"
                                            ${(item?.result?._id && getSaloonId(item)) ? "" : "disabled"}>
                                            Add to Cart
                                        </button>
                                        <button
                                            type="button"
                                            class="btn btn-outline-danger btn-sm wishlist-toggle active"
                                            data-product-id="${item?.result?._id || ""}"
                                            ${(item?.result?._id) ? "" : "disabled"}>
                                            <i class="fas fa-heart"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `).join("");
                    bindActions();
                } catch (error) {
                    renderEmpty("Unable to load wishlist.");
                }
            };

            loadWishlist();
        })();
    </script>
</body>
</html>
