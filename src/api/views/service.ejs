<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>
    <style>
        .wishlist-toggle {
            position: absolute;
            top: 10px;
            right: 10px;
            z-index: 2;
            width: 36px;
            height: 36px;
            border: none;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.92);
            color: #444;
        }
        .wishlist-toggle.active {
            color: #dc3545;
        }
        .cart-stepper {
            display: inline-flex;
            align-items: center;
            border: 1px solid #e5e5e5;
            border-radius: 999px;
            overflow: hidden;
            background: #fff;
        }
        .cart-stepper.d-none {
            display: none !important;
        }
        .cart-add-btn {
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #0d6efd;
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .cart-add-btn.d-none {
            display: none !important;
        }
        .cart-stepper button {
            border: none;
            width: 34px;
            height: 34px;
            background: #f5f5f5;
            font-weight: 700;
        }
        .cart-stepper .qty {
            width: 38px;
            text-align: center;
            font-weight: 700;
            color: #0d6efd;
        }
        .checkout-btn {
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #198754;
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: 8px;
        }
    </style>

    <body>
        <!-- Spinner Start -->
        <div id="spinner"
            class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50  d-flex align-items-center justify-content-center">
            <div class="spinner-grow text-primary" role="status"></div>
        </div>
        <!-- Spinner End -->

        <%- include('./partials/header.ejs') %>

            <!-- Header Start -->
            <div class="container-fluid bg-breadcrumb py-5">
                <div class="container text-center py-5">
                    <h3 class="text-white display-3 mb-4">Our Services</h1>
                        <ol class="breadcrumb justify-content-center mb-0">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item"><a href="#">Pages</a></li>
                            <li class="breadcrumb-item active text-white">Service Page</li>
                        </ol>
                </div>
            </div>
            <!-- Header End -->


            <!-- Services Start -->
            <div class="container-fluid services py-5">
                <div class="container py-5">
                    <div class="mx-auto text-center mb-5" style="max-width: 800px;">
                        <p class="fs-4 text-uppercase text-center text-primary">Our Service</p>
                        <h1 class="display-3">Spa & Beauty Services</h1>
                    </div>
                    <div class="row mb-5">
                        <div class="col-12">
                            <div class="owl-carousel service-category-carousel">
                                <% if (data?.category?.length) { %>
                                    <% data.category.forEach((cat) => { %>
                                        <div class="text-center p-2">
                                            <div class="mx-auto mb-2 rounded-circle overflow-hidden border border-2 border-primary"
                                                style="width: 96px; height: 96px;">
                                                <img src="<%= cat.image ? '/uploads/' + cat.image : '/web/img/services-1.jpg' %>"
                                                    class="img-fluid w-100 h-100" style="object-fit: cover;"
                                                    alt="<%= cat.Name || 'Category' %>">
                                            </div>
                                            <h6 class="mb-0"><%= cat.Name %></h6>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="text-center p-2">
                                        <div class="mx-auto mb-2 rounded-circle overflow-hidden border border-2 border-primary"
                                            style="width: 96px; height: 96px;">
                                            <img src="/web/img/services-1.jpg" class="img-fluid w-100 h-100"
                                                style="object-fit: cover;" alt="Category">
                                        </div>
                                        <h6 class="mb-0">Skin Care</h6>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4">
                        <% if (data?.products?.length) { %>
                            <% data.products.forEach((product) => { %>
                                <% const productImage = Array.isArray(product.image) ? product.image[0] : product.image; %>
                                <% const imagePath = productImage ? (String(productImage).startsWith('http') ? productImage : '/uploads/' + productImage) : '/web/img/services-1.jpg'; %>
                                <div class="col-md-6 col-lg-4">
                                    <div class="services-item bg-light border-4 border-end border-primary rounded p-4 h-100">
                                        <div class="services-img rounded mb-3 position-relative" style="height: 190px; overflow: hidden;">
                                            <button
                                                type="button"
                                                class="wishlist-toggle"
                                                data-saloon-id="<%= product.saloonStore || '' %>"
                                                title="Add to Wishlist"
                                                <%= product.saloonStore ? '' : 'disabled' %>>
                                                <i class="fas fa-heart"></i>
                                            </button>
                                            <img src="<%= imagePath %>" class="img-fluid w-100 h-100" style="object-fit: cover;"
                                                alt="<%= product.ServiceName || 'Product' %>">
                                        </div>
                                        <h4 class="mb-2"><%= product.ServiceName || 'Service' %></h4>
                                        <p class="mb-2 text-muted"><%= product.description || '' %></p>
                                        <div class="d-flex align-items-center justify-content-between mt-3">
                                            <h5 class="text-primary mb-0">Rs. <%= Number(product.ServicePrice || 0) %></h5>
                                            <div class="cart-action"
                                                data-service-id="<%= product._id %>"
                                                data-saloon-id="<%= product.saloonStore || '' %>">
                                                <button type="button" class="cart-add-btn" <%= product.saloonStore ? '' : 'disabled' %>>
                                                    <i class="fas fa-shopping-cart"></i>
                                                </button>
                                                <div class="cart-stepper d-none">
                                                    <button type="button" class="qty-minus" <%= product.saloonStore ? '' : 'disabled' %>>-</button>
                                                    <span class="qty">0</span>
                                                    <button type="button" class="qty-plus" <%= product.saloonStore ? '' : 'disabled' %>>+</button>
                                                </div>
                                                <button type="button" class="checkout-btn" title="Checkout"
                                                    <%= product.saloonStore ? '' : 'disabled' %>>
                                                    <i class="fas fa-credit-card"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-12 text-center">
                                <p class="mb-0">No products found.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <script>
                (function () {
                    const getAuthToken = () => {
                        const keys = ["auth", "token", "accessToken"];
                        for (const key of keys) {
                            const value = localStorage.getItem(key);
                            if (value) return value;
                        }
                        return "";
                    };

                    const showMessage = (message) => {
                        if (!message) return;
                        alert(message);
                    };

                    const getHeaders = () => ({ Authorization: `Bearer ${getAuthToken()}` });
                    const cartActions = Array.from(document.querySelectorAll(".cart-action"));
                    const wishlistButtons = Array.from(document.querySelectorAll(".wishlist-toggle"));
                    const serviceState = {};
                    const wishlistState = {};

                    const updateQtyUi = () => {
                        cartActions.forEach((action) => {
                            const serviceId = action.getAttribute("data-service-id");
                            const qty = Number(serviceState[serviceId]?.qty || 0);
                            const addBtn = action.querySelector(".cart-add-btn");
                            const stepper = action.querySelector(".cart-stepper");
                            const qtyEl = action.querySelector(".qty");
                            if (qtyEl) qtyEl.textContent = String(qty);
                            if (qty <= 0) {
                                addBtn?.classList.remove("d-none");
                                stepper?.classList.add("d-none");
                            } else {
                                addBtn?.classList.add("d-none");
                                stepper?.classList.remove("d-none");
                            }
                        });
                    };

                    const updateWishlistUi = () => {
                        wishlistButtons.forEach((btn) => {
                            const saloonId = btn.getAttribute("data-saloon-id");
                            btn.classList.toggle("active", Boolean(wishlistState[saloonId]));
                        });
                    };

                    const syncCartState = async () => {
                        if (!getAuthToken()) return;
                        try {
                            const response = await fetch("/get-cart", { headers: getHeaders() });
                            const result = await response.json();
                            Object.keys(serviceState).forEach((key) => delete serviceState[key]);
                            if (response.ok && result?.status && Array.isArray(result.data)) {
                                result.data.forEach((saloonEntry) => {
                                    const cartItems = Array.isArray(saloonEntry.cart) ? saloonEntry.cart : [];
                                    cartItems.forEach((item) => {
                                        const serviceId = item?.cartdata?.serviceId;
                                        if (!serviceId) return;
                                        const serviceKey = String(serviceId);
                                        const itemQty = Number(item?.cartdata?.quantity || 1);
                                        if (!serviceState[serviceKey]) {
                                            serviceState[serviceKey] = { qty: 0, cartId: String(item._id || "") };
                                        }
                                        serviceState[serviceKey].qty += itemQty;
                                        if (!serviceState[serviceKey].cartId && item?._id) {
                                            serviceState[serviceKey].cartId = String(item._id);
                                        }
                                    });
                                });
                            }
                            updateQtyUi();
                            const totalQty = Object.values(serviceState).reduce((sum, item) => sum + Number(item.qty || 0), 0);
                            window.dispatchEvent(new CustomEvent("cart:updated", { detail: { count: totalQty } }));
                        } catch (error) {
                        }
                    };

                    const syncWishlistState = async () => {
                        if (!getAuthToken()) return;
                        try {
                            const response = await fetch("/get-wishlist", { headers: getHeaders() });
                            const result = await response.json();
                            Object.keys(wishlistState).forEach((key) => delete wishlistState[key]);
                            if (response.ok && result?.status && Array.isArray(result.data)) {
                                result.data.forEach((item) => {
                                    const saloonId = item?.result?._id || item?.saloonId;
                                    if (saloonId) wishlistState[String(saloonId)] = true;
                                });
                            }
                            updateWishlistUi();
                        } catch (error) {
                        }
                    };

                    const addOneToCart = async ({ serviceId, saloonId, triggerBtn }) => {
                        const token = getAuthToken();
                        if (!token) {
                            showMessage("Please login first to add product to cart.");
                            return;
                        }
                        if (!serviceId || !saloonId) {
                            showMessage("Invalid service details.");
                            return;
                        }
                        if (triggerBtn) triggerBtn.disabled = true;
                        try {
                            const response = await fetch(`/add-cart?serviceId=${serviceId}&saloonId=${saloonId}`, {
                                method: "GET",
                                headers: getHeaders(),
                            });
                            const result = await response.json();
                            if (!(response.ok && result?.status)) {
                                showMessage(result?.message || "Unable to add to cart.");
                            }
                            await syncCartState();
                        } catch (error) {
                            showMessage("Unable to add to cart right now.");
                        } finally {
                            if (triggerBtn) triggerBtn.disabled = false;
                        }
                    };

                    cartActions.forEach((action) => {
                        const addBtn = action.querySelector(".cart-add-btn");
                        const plusBtn = action.querySelector(".qty-plus");
                        const minusBtn = action.querySelector(".qty-minus");
                        const checkoutBtn = action.querySelector(".checkout-btn");
                        const serviceId = action.getAttribute("data-service-id");
                        const saloonId = action.getAttribute("data-saloon-id");

                        addBtn?.addEventListener("click", async () => {
                            await addOneToCart({ serviceId, saloonId, triggerBtn: addBtn });
                        });

                        plusBtn?.addEventListener("click", async () => {
                            const token = getAuthToken();
                            if (!token) {
                                showMessage("Please login first to add product to cart.");
                                return;
                            }
                            await addOneToCart({ serviceId, saloonId, triggerBtn: plusBtn });
                        });

                        minusBtn?.addEventListener("click", async () => {
                            const token = getAuthToken();
                            if (!token) {
                                showMessage("Please login first.");
                                return;
                            }
                            const state = serviceState[String(serviceId)];
                            if (!state || !state.qty || !state.cartId) return;

                            minusBtn.disabled = true;
                            try {
                                const response = await fetch(`/remove-service-from-cart?id=${state.cartId}&serviceId=${serviceId}`, {
                                    method: "GET",
                                    headers: getHeaders(),
                                });
                                const result = await response.json();
                                if (!(response.ok && result?.status)) {
                                    showMessage(result?.message || "Unable to update cart.");
                                }
                                await syncCartState();
                            } catch (error) {
                                showMessage("Unable to update cart right now.");
                            } finally {
                                minusBtn.disabled = false;
                            }
                        });

                        checkoutBtn?.addEventListener("click", () => {
                            const token = getAuthToken();
                            if (!token) {
                                showMessage("Please login first.");
                                return;
                            }
                            window.location.href = "/my-orders";
                        });
                    });

                    wishlistButtons.forEach((button) => {
                        button.addEventListener("click", async () => {
                            const token = getAuthToken();
                            const saloonId = button.getAttribute("data-saloon-id");
                            if (!token) {
                                showMessage("Please login first to update wishlist.");
                                return;
                            }
                            if (!saloonId) {
                                showMessage("Invalid wishlist item.");
                                return;
                            }
                            button.disabled = true;
                            try {
                                const response = await fetch(`/wishlist?id=${saloonId}`, {
                                    method: "GET",
                                    headers: getHeaders(),
                                });
                                const result = await response.json();
                                if (response.ok && result?.status) {
                                    await syncWishlistState();
                                } else {
                                    showMessage(result?.message || "Unable to update wishlist.");
                                }
                            } catch (error) {
                                showMessage("Unable to update wishlist right now.");
                            } finally {
                                button.disabled = false;
                            }
                        });
                    });

                    syncCartState();
                    syncWishlistState();
                })();
            </script>




            <!-- Pricing Start -->
            <div class="container-fluid pricing py-5" style="background: var(--bs-primary);">
                <div class="container py-5">
                    <div class="owl-carousel pricing-carousel">
                        <% (data?.pricingPlans || []).forEach(function(plan) { %>
                        <div class="pricing-item">
                            <div class="pricing-content rounded">
                                <div
                                    class="d-flex align-items-center justify-content-between bg-light rounded-top border-3 border-bottom border-primary p-4">
                                    <h1 class="display-4 mb-0">
                                        <small class="align-top text-muted"
                                            style="font-size: 22px; line-height: 45px;">$</small><%= plan.price %><small
                                            class="text-muted" style="font-size: 16px; line-height: 40px;"><%= plan.durationLabel || "/Session" %></small>
                                    </h1>
                                    <h5 class="text-primary text-uppercase m-0"><%= plan.name %></h5>
                                </div>
                                <div class="p-4">
                                    <% (plan.features || []).forEach(function(feature) { %>
                                        <p><i class="fa fa-check text-primary me-2"></i><%= feature %></p>
                                    <% }) %>
                                    <a href="/appointment"
                                        class="btn btn-primary btn-primary-outline-0 rounded-pill my-2 px-4"><%= plan.ctaLabel || "Book Now" %>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
            </div>
            <!-- Pricing End -->

            <%- include('./partials/footerlink.ejs') %>
    </body>

</html>
