<!DOCTYPE html>
<html lang="en">
<%- include("./partials/head.ejs") %>
<body>
    <div id="spinner" class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>

    <%- include("./partials/header.ejs") %>

    <div class="container-fluid bg-breadcrumb py-5">
        <div class="container text-center py-5">
            <h3 class="text-white display-3 mb-4">Our Team</h3>
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active text-white">Team</li>
            </ol>
        </div>
    </div>

    <div class="container-fluid team py-5">
        <div class="container py-5">
            <div class="text-center mx-auto mb-5" style="max-width: 800px;">
                <p class="fs-4 text-uppercase text-primary">Experts</p>
                <h1 class="display-4 mb-4">Salon Specialists</h1>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-3">
                    <div class="team-item">
                        <div class="team-img rounded-top">
                            <img src="/web/img/team-1.png" class="img-fluid w-100 rounded-top bg-light" alt="Team Member">
                        </div>
                        <div class="team-text rounded-bottom text-center p-4">
                            <h3 class="text-white">Olivia Mia</h3>
                            <p class="mb-0 text-white">Hair Stylist</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="team-item">
                        <div class="team-img rounded-top">
                            <img src="/web/img/team-2.png" class="img-fluid w-100 rounded-top bg-light" alt="Team Member">
                        </div>
                        <div class="team-text rounded-bottom text-center p-4">
                            <h3 class="text-white">Charlotte Ross</h3>
                            <p class="mb-0 text-white">Skin Expert</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="team-item">
                        <div class="team-img rounded-top">
                            <img src="/web/img/team-3.png" class="img-fluid w-100 rounded-top bg-light" alt="Team Member">
                        </div>
                        <div class="team-text rounded-bottom text-center p-4">
                            <h3 class="text-white">Amelia Luna</h3>
                            <p class="mb-0 text-white">Nail Artist</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="team-item">
                        <div class="team-img rounded-top">
                            <img src="/web/img/team-4.png" class="img-fluid w-100 rounded-top bg-light" alt="Team Member">
                        </div>
                        <div class="team-text rounded-bottom text-center p-4">
                            <h3 class="text-white">Isabella Eva</h3>
                            <p class="mb-0 text-white">Makeup Artist</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include("./partials/footerlink.ejs") %>
</body>
</html>
