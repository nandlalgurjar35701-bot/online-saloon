<!-- Footer Start -->
<div class="container-fluid footer py-5">
    <div class="container py-5">
        <div class="row g-5">
            <div class="col-md-6 col-lg-6 col-xl-3">
                <div class="footer-item">
                    <h4 class="mb-4 text-white">Newsletter</h4>
                    <p class="text-white">
                        Get salon updates, offers and grooming tips straight to your inbox.
                    </p>
                    <form action="/newsletter" method="post" class="position-relative mx-auto rounded-pill">
                        <input class="form-control rounded-pill border-0 w-100 py-3 ps-4 pe-5" type="email" name="email"
                            placeholder="Enter your email" required>
                        <button type="submit"
                            class="btn btn-primary btn-primary-outline-0 rounded-pill position-absolute top-0 end-0 py-2 mt-2 me-2">SignUp</button>
                    </form>
                </div>
            </div>
            <div class="col-md-6 col-lg-6 col-xl-3">
                <div class="footer-item d-flex flex-column">
                    <h4 class="mb-4 text-white">Our Services</h4>
                    <% if (data?.category?.length) { %>
                        <% data.category.slice(0, 7).forEach(function(cat) { %>
                            <a href="/service"><i class="fas fa-angle-right me-2"></i> <%= cat.Name %></a>
                        <% }) %>
                    <% } else { %>
                        <a href="/service"><i class="fas fa-angle-right me-2"></i> Hair Styling</a>
                        <a href="/service"><i class="fas fa-angle-right me-2"></i> Skincare</a>
                        <a href="/service"><i class="fas fa-angle-right me-2"></i> Makeup</a>
                    <% } %>
                </div>
            </div>
            <div class="col-md-6 col-lg-6 col-xl-3">
                <div class="footer-item d-flex flex-column">
                    <h4 class="mb-4 text-white">Schedule</h4>
                    <p class="text-muted mb-0">Mon-Fri: <span class="text-white"> <%= data?.siteSetting?.openingHours?.monFri || "09:00 AM - 09:00 PM" %></span></p>
                    <p class="text-muted mb-0">Saturday: <span class="text-white"> <%= data?.siteSetting?.openingHours?.saturday || "09:00 AM - 08:00 PM" %></span></p>
                    <p class="text-muted mb-0">Sunday: <span class="text-white"> <%= data?.siteSetting?.openingHours?.sunday || "10:00 AM - 06:00 PM" %></span></p>
                    <h4 class="my-4 text-white">Address</h4>
                    <p class="mb-0"><i class="fas fa-map-marker-alt text-secondary me-2"></i> <%= data?.siteSetting?.address || "123 ranking street North tower New York, USA" %></p>
                </div>
            </div>
            <div class="col-md-6 col-lg-6 col-xl-3">
                <div class="footer-item d-flex flex-column">
                    <h4 class="mb-4 text-white">Follow Us</h4>
                    <a href="<%= data?.siteSetting?.socialLinks?.facebook || '#' %>"><i class="fas fa-angle-right me-2"></i> Facebook</a>
                    <a href="<%= data?.siteSetting?.socialLinks?.instagram || '#' %>"><i class="fas fa-angle-right me-2"></i> Instagram</a>
                    <a href="<%= data?.siteSetting?.socialLinks?.twitter || '#' %>"><i class="fas fa-angle-right me-2"></i> Twitter</a>
                    <h4 class="my-4 text-white">Contact Us</h4>
                    <p class="mb-0"><i class="fas fa-envelope text-secondary me-2"></i> <%= data?.siteSetting?.email || "info@example.com" %></p>
                    <p class="mb-0"><i class="fas fa-phone text-secondary me-2"></i> <%= data?.siteSetting?.phone || "(+012) 3456 7890 123" %></p>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Footer End -->

<!-- Back to Top -->
<a href="#" class="btn btn-primary btn-primary-outline-0 btn-md-square rounded-circle back-to-top"><i
        class="fa fa-arrow-up"></i></a>

<!-- JavaScript Libraries -->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/web/lib/wow/wow.min.js"></script>
<script src="/web/lib/easing/easing.min.js"></script>
<script src="/web/lib/waypoints/waypoints.min.js"></script>
<script src="/web/lib/counterup/counterup.min.js"></script>
<script src="/web/lib/lightbox/js/lightbox.min.js"></script>
<script src="/web/lib/owlcarousel/owl.carousel.min.js"></script>

<!-- Template Javascript -->
<script src="/web/js/main.js"></script>
<script>
(function () {
    const STORAGE_KEY = 'siteConfig';
    fetch('/get-site-config')
        .then(function (r) { return r.json(); })
        .then(function (res) {
            if (res && res.status && res.data) {
                try {
                    localStorage.setItem(STORAGE_KEY, JSON.stringify(res.data));
                    applySiteConfig(res.data);
                } catch (e) {}
            }
        })
        .catch(function () {});
    var cached = null;
    try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (raw) cached = JSON.parse(raw);
    } catch (e) {}
    if (cached) applySiteConfig(cached);
    function applySiteConfig(config) {
        if (!config) return;
        var brand = config.siteSetting && config.siteSetting.brandName;
        if (brand) {
            var el = document.getElementById('siteBrandName');
            if (el) el.textContent = brand;
        }
        var title = config.pageTitle;
        if (title) document.title = title;
    }
})();
</script>
