<!-- Navbar start -->
<div class="container-fluid sticky-top px-0">
    <div class="container-fluid bg-light">
        <div class="container px-0">
            <nav class="navbar navbar-light navbar-expand-xl">
                <a href="/" class="navbar-brand">
                    <h1 class="text-primary display-4"><%= data?.siteSetting?.brandName || "Sparlex" %></h1>
                </a>
                <button class="navbar-toggler py-2 px-3" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarCollapse">
                    <span class="fa fa-bars text-primary"></span>
                </button>
                <div class="collapse navbar-collapse bg-light py-3" id="navbarCollapse">
                    <% 
                        const routePath = String(currentPath || "/").toLowerCase();
                        const pagesPaths = ["/team", "/testimonial", "/gallery", "/appointment", "/404"];
                        const isActivePath = (paths) => paths.includes(routePath) ? " active" : "";
                    %>
                    <div class="navbar-nav mx-auto border-top">
                        <a href="/" class="nav-item nav-link<%= isActivePath(['/']) %>">Home</a>
                        <a href="/about" class="nav-item nav-link<%= isActivePath(['/about']) %>">About</a>
                        <a href="/service" class="nav-item nav-link<%= isActivePath(['/service', '/services']) %>">Services</a>
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle<%= pagesPaths.includes(routePath) ? ' active' : '' %>" data-bs-toggle="dropdown">Pages</a>
                            <div class="dropdown-menu m-0 bg-secondary rounded-0">
                                <a href="/team" class="dropdown-item<%= isActivePath(['/team']) %>">Team</a>
                                <a href="/testimonial" class="dropdown-item<%= isActivePath(['/testimonial']) %>">Testimonial</a>
                                <a href="/gallery" class="dropdown-item<%= isActivePath(['/gallery']) %>">Gallery</a>
                                <a href="/appointment" class="dropdown-item<%= isActivePath(['/appointment']) %>">Appointment</a>
                                <a href="/404" class="dropdown-item<%= isActivePath(['/404']) %>">404 page</a>
                            </div>
                        </div>
                        <a href="/contact" class="nav-item nav-link<%= isActivePath(['/contact']) %>">Contact Us</a>
                    </div>
                    <div class="d-flex align-items-center flex-nowrap pt-xl-0">
                        <button id="headerCartBtn"
                            class="btn-search btn btn-primary btn-primary-outline-0 rounded-circle btn-lg-square position-relative">
                            <i class="fas fa-shopping-cart"></i>

                            <!-- cart count -->
                            <span id="headerCartCount"
                                class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                0
                            </span>
                        </button>
                        <button id="guestAuthBtn" type="button"
                            class="btn btn-primary btn-primary-outline-0 rounded-circle btn-lg-square ms-2"
                            data-bs-toggle="modal" data-bs-target="#authModal" title="Login / Sign Up">
                            <i class="fas fa-user"></i>
                        </button>
                        <div id="userMenuWrapper" class="dropdown ms-2" style="display: none;">
                            <button class="btn btn-primary btn-primary-outline-0 rounded-circle btn-lg-square dropdown-toggle"
                                type="button" id="userMenuBtn" data-bs-toggle="dropdown" aria-expanded="false"
                                title="My Account">
                                <i class="fas fa-user"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuBtn">
                                <li><button class="dropdown-item" type="button" id="menuEditProfile">Edit Profile</button></li>
                                <li><button class="dropdown-item" type="button" id="menuWishlist">Wishlist</button></li>
                                <li><button class="dropdown-item" type="button" id="menuOrders">Orders</button></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><button class="dropdown-item text-danger" type="button" id="menuLogout">Logout</button></li>
                            </ul>
                        </div>
                        <a href="/appointment"
                            class="btn btn-primary btn-primary-outline-0 rounded-pill py-3 px-4 ms-4">Book
                            Appointment</a>
                    </div>
                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Navbar End -->

<% if ((successMessages && successMessages.length) || (errorMessages && errorMessages.length)) { %>
<div class="container mt-3">
    <% (successMessages || []).forEach(function(msg) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% }) %>
    <% (errorMessages || []).forEach(function(msg) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% }) %>
</div>
<% } %>

<div class="modal fade" id="authModal" tabindex="-1" aria-labelledby="authModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="authModalLabel">User Access</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs mb-3" id="authTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="login-tab" data-bs-toggle="tab"
                            data-bs-target="#login-pane" type="button" role="tab">Login</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="signup-tab" data-bs-toggle="tab"
                            data-bs-target="#signup-pane" type="button" role="tab">Sign Up</button>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="login-pane" role="tabpanel" aria-labelledby="login-tab">
                        <form id="loginForm">
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="email" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" class="form-control" name="password" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Login</button>
                        </form>
                    </div>
                    <div class="tab-pane fade" id="signup-pane" role="tabpanel" aria-labelledby="signup-tab">
                        <form id="signupForm">
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" name="name" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Phone</label>
                                <input type="tel" class="form-control" name="phone" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="email" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" class="form-control" name="password" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Sign Up</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const readToken = () => localStorage.getItem("auth") || localStorage.getItem("token") || localStorage.getItem("accessToken") || "";
        const clearToken = () => {
            localStorage.removeItem("auth");
            localStorage.removeItem("token");
            localStorage.removeItem("accessToken");
        };
        const show = (message) => {
            if (message) alert(message);
        };
        const guestAuthBtn = document.getElementById("guestAuthBtn");
        const userMenuWrapper = document.getElementById("userMenuWrapper");
        const headerCartCount = document.getElementById("headerCartCount");
        const headerCartBtn = document.getElementById("headerCartBtn");
        const authModalEl = document.getElementById("authModal");
        const applyAuthUi = () => {
            const token = readToken();
            if (token) {
                if (guestAuthBtn) guestAuthBtn.style.display = "none";
                if (userMenuWrapper) userMenuWrapper.style.display = "block";
            } else {
                if (guestAuthBtn) guestAuthBtn.style.display = "inline-flex";
                if (userMenuWrapper) userMenuWrapper.style.display = "none";
            }
        };
        const closeAuthModal = () => {
            if (!authModalEl || typeof bootstrap === "undefined") return;
            const instance = bootstrap.Modal.getInstance(authModalEl);
            if (instance) instance.hide();
        };
        const syncHeaderCartCount = async () => {
            const token = readToken();
            if (!headerCartCount) return;
            if (!token) {
                headerCartCount.textContent = "0";
                return;
            }
            try {
                const response = await fetch("/get-cart", {
                    headers: { Authorization: `Bearer ${token}` },
                });
                const result = await response.json();
                if (!(response.ok && result?.status) || !Array.isArray(result.data)) {
                    headerCartCount.textContent = "0";
                    return;
                }
                let count = 0;
                result.data.forEach((saloonEntry) => {
                    const cartItems = Array.isArray(saloonEntry.cart) ? saloonEntry.cart : [];
                    cartItems.forEach((item) => {
                        count += Number(item?.cartdata?.quantity || 0);
                    });
                });
                headerCartCount.textContent = String(count);
            } catch (error) {
                headerCartCount.textContent = "0";
            }
        };

        applyAuthUi();
        syncHeaderCartCount();

        if (headerCartBtn) {
            headerCartBtn.addEventListener("click", () => {
                if (!readToken()) {
                    show("Please login first.");
                    return;
                }
                window.location.href = "/my-cart";
            });
        }

        window.addEventListener("cart:updated", (event) => {
            if (!headerCartCount) return;
            const count = Number(event?.detail?.count || 0);
            headerCartCount.textContent = String(count);
        });

        const loginForm = document.getElementById("loginForm");
        if (loginForm) {
            loginForm.addEventListener("submit", async (event) => {
                event.preventDefault();
                const formData = new FormData(loginForm);
                const payload = {
                    email: String(formData.get("email") || "").trim(),
                    password: String(formData.get("password") || "").trim(),
                };
                try {
                    const response = await fetch("/login", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload),
                    });
                    const result = await response.json();
                    if (response.ok && result?.status) {
                        const token = result?.data?.[1]?.auth;
                        if (token) {
                            localStorage.setItem("auth", token);
                            localStorage.setItem("token", token);
                        }
                        closeAuthModal();
                        applyAuthUi();
                        show(result.message || "Login successful.");
                        window.location.reload();
                        return;
                    }
                    show(result?.message || "Login failed.");
                } catch (error) {
                    show("Unable to login right now.");
                }
            });
        }

        const signupForm = document.getElementById("signupForm");
        if (signupForm) {
            signupForm.addEventListener("submit", async (event) => {
                event.preventDefault();
                const formData = new FormData(signupForm);
                const payload = {
                    name: String(formData.get("name") || "").trim(),
                    phone: String(formData.get("phone") || "").trim(),
                    email: String(formData.get("email") || "").trim(),
                    password: String(formData.get("password") || "").trim(),
                };

                try {
                    const otpSent = await fetch("/otp-sent", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ phone: payload.phone }),
                    });
                    const otpSentResult = await otpSent.json();
                    if (!(otpSent.ok && otpSentResult?.status)) {
                        show(otpSentResult?.message || "Unable to send OTP.");
                        return;
                    }

                    const otpVerify = await fetch("/otp-verify", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ phone: payload.phone, otp: "1234" }),
                    });
                    const otpVerifyResult = await otpVerify.json();
                    if (!(otpVerify.ok && otpVerifyResult?.status)) {
                        show(otpVerifyResult?.message || "OTP verification failed.");
                        return;
                    }

                    const registerRes = await fetch("/register", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload),
                    });
                    const registerResult = await registerRes.json();
                    if (registerRes.ok && registerResult?.status) {
                        const token = registerResult?.data?.auth;
                        if (token) {
                            localStorage.setItem("auth", token);
                            localStorage.setItem("token", token);
                        }
                        closeAuthModal();
                        applyAuthUi();
                        show(registerResult.message || "Registration successful.");
                        window.location.reload();
                        return;
                    }
                    show(registerResult?.message || "Sign up failed.");
                } catch (error) {
                    show("Unable to sign up right now.");
                }
            });
        }

        const menuEditProfile = document.getElementById("menuEditProfile");
        if (menuEditProfile) {
            menuEditProfile.addEventListener("click", () => {
                window.location.href = "/my-profile";
            });
        }

        const menuWishlist = document.getElementById("menuWishlist");
        if (menuWishlist) {
            menuWishlist.addEventListener("click", () => {
                window.location.href = "/my-wishlist";
            });
        }

        const menuOrders = document.getElementById("menuOrders");
        if (menuOrders) {
            menuOrders.addEventListener("click", () => {
                window.location.href = "/my-orders";
            });
        }

        const menuLogout = document.getElementById("menuLogout");
        if (menuLogout) {
            menuLogout.addEventListener("click", async () => {
                try {
                    await fetch("/log-Out");
                } catch (error) {
                }
                clearToken();
                applyAuthUi();
                if (headerCartCount) headerCartCount.textContent = "0";
                window.location.reload();
            });
        }
    })();
</script>
