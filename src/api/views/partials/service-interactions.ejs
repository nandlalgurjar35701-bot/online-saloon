<script>
    (function () {
        const getAuthToken = () => {
            const keys = ["auth", "token", "accessToken"];
            for (const key of keys) {
                const value = localStorage.getItem(key);
                if (value) return value;
            }
            return "";
        };

        const showMessage = (message) => {
            if (!message) return;
            alert(message);
        };

        const getHeaders = () => ({ 
            Authorization: `Bearer ${getAuthToken()}`
        });
        const cartActions = Array.from(document.querySelectorAll(".cart-action"));
        const wishlistButtons = Array.from(document.querySelectorAll(".wishlist-toggle"));
        const serviceState = {};
        const wishlistState = {};

        const updateQtyUi = () => {
            cartActions.forEach((action) => {
                const serviceId = action.getAttribute("data-service-id");
                const qty = Number(serviceState[serviceId]?.qty || 0);
                const addBtn = action.querySelector(".cart-add-btn");
                const stepper = action.querySelector(".cart-stepper");
                const qtyEl = action.querySelector(".qty");
                if (qtyEl) qtyEl.textContent = String(qty);
                if (qty <= 0) {
                    addBtn?.classList.remove("d-none");
                    stepper?.classList.add("d-none");
                } else {
                    addBtn?.classList.add("d-none");
                    stepper?.classList.remove("d-none");
                }
            });
        };

        const updateWishlistUi = () => {
            wishlistButtons.forEach((btn) => {
                const productId = btn.getAttribute("data-product-id");
                btn.classList.toggle("active", Boolean(wishlistState[productId]));
            });
        };

        const syncCartState = async () => {
            if (!getAuthToken()) return;
            try {
                const response = await fetch("/get-cart", { headers: getHeaders() });
                const result = await response.json();
                Object.keys(serviceState).forEach((key) => delete serviceState[key]);
                if (response.ok && result?.status && Array.isArray(result.data)) {
                    result.data.forEach((saloonEntry) => {
                        const cartItems = Array.isArray(saloonEntry.cart) ? saloonEntry.cart : [];
                        cartItems.forEach((item) => {
                            const serviceId = item?.cartdata?.serviceId;
                            if (!serviceId) return;
                            const serviceKey = String(serviceId);
                            const itemQty = Number(item?.cartdata?.quantity || 1);
                            if (!serviceState[serviceKey]) {
                                serviceState[serviceKey] = { qty: 0, cartId: String(item._id || "") };
                            }
                            serviceState[serviceKey].qty += itemQty;
                            if (!serviceState[serviceKey].cartId && item?._id) {
                                serviceState[serviceKey].cartId = String(item._id);
                            }
                        });
                    });
                }
                updateQtyUi();
                const totalQty = Object.values(serviceState).reduce((sum, item) => sum + Number(item.qty || 0), 0);
                window.dispatchEvent(new CustomEvent("cart:updated", { detail: { count: totalQty } }));
            } catch (error) {
            }
        };

        const syncWishlistState = async () => {
            if (!getAuthToken()) return;
            try {
                const response = await fetch("/get-wishlist?type=product", { headers: getHeaders() });
                const result = await response.json();
                Object.keys(wishlistState).forEach((key) => delete wishlistState[key]);
                if (response.ok && result?.status && Array.isArray(result.data)) {
                    result.data.forEach((item) => {
                        const productId = item?.result?._id || item?.productId;
                        if (productId) wishlistState[String(productId)] = true;
                    });
                }
                updateWishlistUi();
            } catch (error) {
            }
        };

        const addOneToCart = async ({ serviceId, saloonId, triggerBtn }) => {
            const token = getAuthToken();
            if (!token) {
                showMessage("Please login first to add product to cart.");
                return;
            }
            if (!serviceId || !saloonId) {
                showMessage("Invalid service details.");
                return;
            }
            if (triggerBtn) triggerBtn.disabled = true;
            try {
                const response = await fetch(`/add-cart?serviceId=${serviceId}`, {
                    method: "GET",
                    headers: getHeaders(),
                });
                const result = await response.json();
                if (!(response.ok && result?.status)) {
                    showMessage(result?.message || "Unable to add to cart.");
                }
                await syncCartState();
            } catch (error) {
                showMessage("Unable to add to cart right now.");
            } finally {
                if (triggerBtn) triggerBtn.disabled = false;
            }
        };

        cartActions.forEach((action) => {
            const addBtn = action.querySelector(".cart-add-btn");
            const plusBtn = action.querySelector(".qty-plus");
            const minusBtn = action.querySelector(".qty-minus");
            const checkoutBtn = action.querySelector(".checkout-btn");
            const serviceId = action.getAttribute("data-service-id");
            const saloonId = action.getAttribute("data-saloon-id");

            addBtn?.addEventListener("click", async () => {
                await addOneToCart({ serviceId, saloonId, triggerBtn: addBtn });
            });

            plusBtn?.addEventListener("click", async () => {
                const token = getAuthToken();
                if (!token) {
                    showMessage("Please login first to add product to cart.");
                    return;
                }
                await addOneToCart({ serviceId, saloonId, triggerBtn: plusBtn });
            });

            minusBtn?.addEventListener("click", async () => {
                const token = getAuthToken();
                if (!token) {
                    showMessage("Please login first.");
                    return;
                }
                const state = serviceState[String(serviceId)];
                if (!state || !state.qty || !state.cartId) return;

                minusBtn.disabled = true;
                try {
                    const response = await fetch(`/remove-service-from-cart?id=${state.cartId}&serviceId=${serviceId}`, {
                        method: "GET",
                        headers: getHeaders(),
                    });
                    const result = await response.json();
                    if (!(response.ok && result?.status)) {
                        showMessage(result?.message || "Unable to update cart.");
                    }
                    await syncCartState();
                } catch (error) {
                    showMessage("Unable to update cart right now.");
                } finally {
                    minusBtn.disabled = false;
                }
            });

            checkoutBtn?.addEventListener("click", () => {
                const token = getAuthToken();
                if (!token) {
                    showMessage("Please login first.");
                    return;
                }
                window.location.href = "/my-cart";
            });
        });

        wishlistButtons.forEach((button) => {
            button.addEventListener("click", async () => {
                const token = getAuthToken();
                const productId = button.getAttribute("data-product-id");
                if (!token) {
                    showMessage("Please login first to update wishlist.");
                    return;
                }
                if (!productId) {
                    showMessage("Invalid wishlist item.");
                    return;
                }
                button.disabled = true;
                try {
                    const response = await fetch(`/wishlist?id=${productId}&type=product`, {
                        method: "GET",
                        headers: getHeaders(),
                    });
                    const result = await response.json();
                    if (response.ok && result?.status) {
                        await syncWishlistState();
                    } else {
                        showMessage(result?.message || "Unable to update wishlist.");
                    }
                } catch (error) {
                    showMessage("Unable to update wishlist right now.");
                } finally {
                    button.disabled = false;
                }
            });
        });

        syncCartState();
        syncWishlistState();
    })();
</script>